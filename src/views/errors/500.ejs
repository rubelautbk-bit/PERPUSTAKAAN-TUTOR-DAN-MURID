<div class="card text-center" style="padding:60px 20px;">
  <h1 style="font-size:4rem; margin:0; color:#dc2626;">500</h1>
  <p class="text-muted">Terjadi kesalahan pada server.</p>
  <% if (typeof message !== 'undefined' && message) { %>
    <pre style="background:var(--bg); padding:10px; border-radius:8px; text-align:left; font-size:0.85rem;"><%= message %></pre>
  <% } %>
  <a href="/" class="btn btn-primary mt-2">Kembali ke Beranda</a>
</div>
