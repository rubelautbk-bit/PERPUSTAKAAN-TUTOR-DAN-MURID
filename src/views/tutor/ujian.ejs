<div class="page-header"><h1>Ujian/Kuis</h1><a href="/tutor/ujian/new" class="btn btn-primary">+ Buat</a></div><table class="tbl"><thead><tr><th>Judul</th><th>Tipe</th><th>Soal</th><th>Status</th><th>Aksi</th></tr></thead><tbody><%list.forEach(u=>{%><tr><td><strong><%=u.judul%></strong></td><td><span class="badge"><%=u.tipe%></span></td><td><%=u.jml_soal%></td><td><span class="badge <%=u.status==="aktif"?"":"warn"%>"><%=u.status%></span></td><td class="row-flex"><a href="/tutor/ujian/<%=u.id%>/soal" class="btn btn-sm btn-secondary">Soal</a><a href="/tutor/ujian/<%=u.id%>/hasil" class="btn btn-sm btn-secondary">Hasil</a><%if(u.status==="draft"){%><form method="POST" action="/tutor/ujian/<%=u.id%>/publish"><button class="btn btn-sm btn-primary">Publish</button></form><%}else if(u.status==="aktif"){%><form method="POST" action="/tutor/ujian/<%=u.id%>/tunda"><button class="btn btn-sm btn-warning">Tunda</button></form><%}else if(u.status==="selesai"||u.status==="arsip"){%><span class="text-muted">Selesai</span><%}%></td></tr><%})%></tbody></table>