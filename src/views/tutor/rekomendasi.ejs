<div class="page-header"><h1>Rekomendasi Buku</h1></div>

<div class="grid-2">
  <div class="card">
    <h3>Rekomendasikan Buku</h3>
    <form method="POST" action="/tutor/rekomendasi">
      <div class="form-group">
        <label>Buku</label>
        <select name="buku_id" class="form-control" required>
          <% bukuList.forEach(b => { %>
            <option value="<%= b.id %>"><%= b.judul %> - <%= b.penulis %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Ke Kelas (opsional)</label>
        <select name="kelas_id" class="form-control">
          <option value="">Untuk semua murid</option>
          <% kelasList.forEach(k => { %><option value="<%= k.id %>"><%= k.nama %></option><% }) %>
        </select>
      </div>
      <div class="form-group"><label>Catatan</label><textarea name="catatan" class="form-control" placeholder="Kenapa buku ini direkomendasikan?"></textarea></div>
      <button class="btn btn-primary">Simpan</button>
    </form>
  </div>

  <div class="card">
    <h3>Daftar Rekomendasi</h3>
    <% list.forEach(r => { %>
      <div style="padding:12px 0; border-bottom:1px solid var(--border);">
        <div class="row-flex" style="justify-content:space-between;">
          <div>
            <strong><%= r.judul %></strong>
            <div class="text-muted" style="font-size:0.85rem;">oleh <%= r.penulis %> &middot; <%= r.kelas_nama || 'Publik' %></div>
          </div>
          <form method="POST" action="/tutor/rekomendasi/<%= r.id %>?_method=DELETE"><button class="btn btn-sm btn-danger">X</button></form>
        </div>
        <% if (r.catatan) { %><p class="text-muted" style="margin:4px 0; font-size:0.9rem;">&quot;<%= r.catatan %>&quot;</p><% } %>
      </div>
    <% }) %>
    <% if (list.length === 0) { %><p class="text-muted">Belum ada rekomendasi.</p><% } %>
  </div>
</div>
