<div class="page-header">
  <div><h1>Bank Soal</h1><p class="subtitle"><%= soal.length %> soal tersedia</p></div>
  <div class="row-flex">
    <a href="/tutor/bank-soal/template.xlsx" class="btn btn-secondary">&#128229; Template</a>
    <a href="/tutor/bank-soal/export.xlsx<%= currentSubtest?'?subtest='+currentSubtest:'' %>" class="btn btn-secondary">Export</a>
    <a href="/tutor/bank-soal/tambah?subtest=<%= currentSubtest %>" class="btn btn-primary">+ Tambah Soal</a>
  </div>
</div>

<div class="card" style="padding:8px;">
  <strong>Filter Subtest:</strong>
  <div class="row-flex" style="margin-top:6px;">
    <a href="/tutor/bank-soal" class="btn btn-sm <%= !currentSubtest?'btn-primary':'btn-secondary' %>">Semua</a>
    <% subtests.forEach(function(st) { %>
      <a href="/tutor/bank-soal?subtest=<%= st %>" class="btn btn-sm <%= currentSubtest===st?'btn-primary':'btn-secondary' %>"><%= st %></a>
    <% }) %>
  </div>
</div>

<div class="card">
  <h3>Import Soal (Excel / CSV)</h3>
  <form method="POST" action="/tutor/bank-soal/import" enctype="multipart/form-data" class="row-flex" style="gap:8px;align-items:center;">
    <input type="file" name="file" accept=".xlsx,.xls,.csv,.docx" class="form-control" required style="max-width:320px;"/>
    <button class="btn btn-primary">Import</button>
  </form>
  <p class="text-muted" style="font-size:0.85rem;margin-top:6px;">
    Kolom: <code>subtest, soal, tipe, opsi_json, jawaban_json, poin, penjelasan</code>. Format <code>.docx</code> juga didukung (lihat template). Download template untuk contoh.
  </p>
</div>

<div class="card mt-3">
  <h3>Daftar Soal</h3>
  <table class="tbl">
    <thead><tr><th>#</th><th>Soal</th><th>Tipe</th><th>Subtest</th><th>Poin</th><th></th></tr></thead>
    <tbody>
      <% soal.forEach(function(s, i) { %>
        <tr>
          <td><%= i+1 %></td>
          <td style="max-width:400px;"><%- s.soal.substring(0, 150) %><%= s.soal.length>150?'...':'' %></td>
          <td><span class="badge"><%= s.tipe %></span></td>
          <td><%= s.subtest %></td>
          <td><%= s.poin %></td>
          <td>
            <div class="row-flex" style="gap:4px;">
              <button type="button" class="btn btn-sm btn-secondary" onclick="lihatSoal(<%= s.id %>, '/tutor/bank-soal/<%= s.id %>/json')">Lihat</button>
              <a href="/tutor/bank-soal/<%= s.id %>" class="btn btn-sm btn-secondary">Edit</a>
              <form method="POST" action="/tutor/bank-soal/<%= s.id %>?_method=DELETE" onsubmit="return confirm('Hapus?')">
                <button class="btn btn-sm btn-danger">X</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (soal.length === 0) { %>
        <tr><td colspan="6" class="text-muted text-center">Belum ada soal.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>


<%- include('../partials/soal-modal') %>
