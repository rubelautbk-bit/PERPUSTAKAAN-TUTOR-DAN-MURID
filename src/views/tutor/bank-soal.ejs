<div class="page-header"><h1>Bank Soal</h1><a href="/tutor/bank-soal/tambah?subtest=<%=currentSubtest%>" class="btn btn-primary">+ Tambah</a></div><div class="row-flex mb-2"><%subtests.forEach(st=>{%><a href="/tutor/bank-soal?subtest=<%=st%>" class="btn btn-sm <%=currentSubtest===st?"btn-primary":"btn-secondary"%>"><%=st%></a><%})%></div><table class="tbl"><thead><tr><th>#</th><th>Soal</th><th>Tipe</th><th>Poin</th><th></th></tr></thead><tbody><%soal.forEach((s,i)=>{%><tr><td><%=i+1%></td><td style="max-width:400px"><%-s.soal.substring(0,100)%></td><td><span class="badge"><%=s.tipe%></span></td><td><%=s.poin%></td><td><form method="POST" action="/tutor/bank-soal/<%=s.id%>?_method=DELETE"><button class="btn btn-sm btn-danger">X</button></form></td></tr><%})%></tbody></table>