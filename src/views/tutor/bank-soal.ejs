<div class="page-header">
  <div><h1>Bank Soal</h1><p class="subtitle"><%= soal.length %> soal tersedia</p></div>
  <a href="/tutor/bank-soal/tambah?subtest=<%= currentSubtest %>" class="btn btn-primary">+ Tambah Soal</a>
</div>

<div class="card" style="padding:8px;">
  <strong>Filter Subtest:</strong>
  <div class="row-flex" style="margin-top:6px;">
    <a href="/tutor/bank-soal" class="btn btn-sm <%= !currentSubtest?'btn-primary':'btn-secondary' %>">Semua</a>
    <% subtests.forEach(function(st) { %>
      <a href="/tutor/bank-soal?subtest=<%= st %>" class="btn btn-sm <%= currentSubtest===st?'btn-primary':'btn-secondary' %>"><%= st %></a>
    <% }) %>
  </div>
</div>

<div class="card">
  <table class="tbl">
    <thead><tr><th>#</th><th>Soal</th><th>Tipe</th><th>Subtest</th><th>Poin</th><th></th></tr></thead>
    <tbody>
      <% soal.forEach(function(s, i) { %>
        <tr>
          <td><%= i+1 %></td>
          <td style="max-width:400px;"><%- s.soal.substring(0, 150) %><%= s.soal.length>150?'...':'' %></td>
          <td><span class="badge"><%= s.tipe %></span></td>
          <td><%= s.subtest %></td>
          <td><%= s.poin %></td>
          <td>
            <form method="POST" action="/tutor/bank-soal/<%= s.id %>?_method=DELETE" onsubmit="return confirm('Hapus?')">
              <button class="btn btn-sm btn-danger">X</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (soal.length === 0) { %>
        <tr><td colspan="6" class="text-muted text-center">Belum ada soal.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
