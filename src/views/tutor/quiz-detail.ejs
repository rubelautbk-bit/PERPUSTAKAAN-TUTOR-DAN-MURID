<div class="page-header">
  <div>
    <a href="/tutor/quiz" class="text-muted">&larr; Semua Quiz</a>
    <h1 style="margin:4px 0;"><%= quiz.judul %></h1>
    <p class="subtitle"><%= quiz.deskripsi || '' %></p>
  </div>
</div>

<div class="grid-2">
  <div class="card">
    <h3>Tambah Soal</h3>
    <form method="POST" action="/tutor/quiz/<%= quiz.id %>/soal">
      <div class="form-group"><label>Pertanyaan</label><textarea name="soal" class="form-control" required></textarea></div>
      <div class="form-row">
        <div class="form-group"><label>A</label><input name="opsi_a" class="form-control"/></div>
        <div class="form-group"><label>B</label><input name="opsi_b" class="form-control"/></div>
        <div class="form-group"><label>C</label><input name="opsi_c" class="form-control"/></div>
        <div class="form-group"><label>D</label><input name="opsi_d" class="form-control"/></div>
      </div>
      <div class="form-group">
        <label>Jawaban Benar</label>
        <select name="jawaban" class="form-control">
          <option value="A">A</option><option value="B">B</option>
          <option value="C">C</option><option value="D">D</option>
        </select>
      </div>
      <button class="btn btn-primary">Tambah Soal</button>
    </form>
  </div>
  <div class="card">
    <h3>Daftar Soal (<%= soal.length %>)</h3>
    <% soal.forEach((s,i) => { %>
      <div style="padding:10px 0; border-bottom:1px solid var(--border);">
        <strong><%= i+1 %>. <%= s.soal %></strong>
        <div class="text-muted" style="font-size:0.88rem; margin-top:4px;">
          A. <%= s.opsi_a %><br>
          B. <%= s.opsi_b %><br>
          C. <%= s.opsi_c %><br>
          D. <%= s.opsi_d %>
        </div>
        <span class="badge mt-1">Jawaban: <%= s.jawaban %></span>
      </div>
    <% }) %>
  </div>
</div>

<div class="card mt-3">
  <h3>Hasil Murid</h3>
  <table class="tbl">
    <thead><tr><th>Murid</th><th>Nilai</th><th>Status</th></tr></thead>
    <tbody>
      <% jawaban.forEach(j => { %>
        <tr>
          <td><%= j.name %></td>
          <td><strong><%= j.nilai %></strong></td>
          <td><span class="badge <%= j.selesai ? '' : 'warn' %>"><%= j.selesai ? 'Selesai' : 'Belum' %></span></td>
        </tr>
      <% }) %>
      <% if (jawaban.length === 0) { %><tr><td colspan="3" class="text-muted text-center">Belum ada yang mengerjakan.</td></tr><% } %>
    </tbody>
  </table>
</div>
