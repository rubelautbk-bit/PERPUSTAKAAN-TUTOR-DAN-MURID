<div class="page-header"><h1>Forum Diskusi</h1></div>

<div class="grid-2">
  <div class="card">
    <h3>Posting Topik</h3>
    <form method="POST" action="/tutor/forum">
      <div class="form-group"><label>Judul</label><input name="judul" class="form-control" required/></div>
      <div class="form-group">
        <label>Kategori</label>
        <select name="kategori" class="form-control">
          <option value="diskusi">Diskusi</option>
          <option value="tanya-jawab">Tanya Jawab</option>
          <option value="rekomendasi">Rekomendasi</option>
          <option value="umum">Umum</option>
        </select>
      </div>
      <div class="form-group"><label>Isi</label><textarea name="isi" class="form-control" rows="4" required></textarea></div>
      <button class="btn btn-primary">Posting</button>
    </form>
  </div>
  <div class="card">
    <h3>Semua Topik</h3>
    <% list.forEach(f => { %>
      <div style="padding:10px 0; border-bottom:1px solid var(--border);">
        <a href="/tutor/forum/<%= f.id %>" style="font-weight:600; color:var(--text);"><%= f.judul %></a>
        <div class="text-muted" style="font-size:0.85rem;">
          <span class="badge"><%= f.kategori %></span>
          &middot; <%= f.name %>
          &middot; <%= f.komentar %> komentar
        </div>
      </div>
    <% }) %>
  </div>
</div>
