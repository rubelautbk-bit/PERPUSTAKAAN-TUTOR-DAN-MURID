<div class="page-header"><h1>Tambah Soal</h1><a href="/tutor/bank-soal" class="btn btn-secondary">Kembali</a></div><div class="card" style="background:var(--brand-light);border:0;padding:14px;margin-bottom:16px;"><strong>LaTeX:</strong> <code>$\frac{a}{b}$</code> inline, <code>914\int_0^1 x dx914</code> display</div><form method="POST" action="/tutor/bank-soal" class="card"><div class="form-row"><div class="form-group"><label>Subtest</label><select name="subtest" class="form-control"><%subtests.forEach(st=>{%><option value="<%=st%>" <%=subtest===st?"selected":""%>><%=st%></option><%})%></select></div><div class="form-group"><label>Tipe</label><select name="tipe" class="form-control"><option value="pg">Pilihan Ganda</option><option value="pg_kompleks">PG Kompleks</option><option value="benar_salah">Benar/Salah</option><option value="isian">Isian</option><option value="esai">Esai</option><option value="menjodohkan">Menjodohkan</option><option value="drag_drop">Drag & Drop</option><option value="labeling">Pelabelan</option></select></div><div class="form-group"><label>Poin</label><input type="number" name="poin" class="form-control" value="1" min="1"/></div></div><div class="form-group"><label>Soal (LaTeX OK)</label><textarea name="soal" class="form-control" rows="6" required></textarea></div><div class="form-group"><label>Opsi (JSON)</label><textarea name="opsi_json" class="form-control" rows="3">["A","B","C","D"]</textarea></div><div class="form-group"><label>Jawaban (JSON)</label><input name="jawaban_json" class="form-control" placeholder=""A" atau ["A","C"]"/></div><div class="form-group"><label>Penjelasan</label><textarea name="penjelasan" class="form-control" rows="2"></textarea></div><button class="btn btn-primary">Simpan</button></form>