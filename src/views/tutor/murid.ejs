<div class="page-header"><h1>Daftar Murid</h1></div>

<table class="tbl">
  <thead><tr><th>Nama</th><th>Email</th><th>No HP</th><th>Kelas</th></tr></thead>
  <tbody>
    <% list.forEach(m => { %>
      <tr>
        <td><strong><%= m.name %></strong></td>
        <td><%= m.email %></td>
        <td><%= m.phone || '-' %></td>
        <td><span class="badge"><%= m.kelas_nama %></span></td>
      </tr>
    <% }) %>
    <% if (list.length === 0) { %><tr><td colspan="4" class="text-muted text-center">Belum ada murid. Buat kelas dan undang murid terlebih dahulu.</td></tr><% } %>
  </tbody>
</table>
