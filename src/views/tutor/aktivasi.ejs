<div class="page-header"><h1>Aktivasi Keanggotaan</h1></div><table class="tbl"><thead><tr><th>Nama</th><th>Email</th><th>HP</th><th>Role</th><th>Tanggal</th><th>Aksi</th></tr></thead><tbody><%pending.forEach(u=>{%><tr><td><strong><%=u.name%></strong></td><td><%=u.email%></td><td><%=u.phone||"-"%></td><td><span class="badge"><%=u.role%></span></td><td><%=new Date(u.created_at).toLocaleDateString("id-ID")%></td><td class="row-flex"><form method="POST" action="/tutor/aktivasi/<%=u.id%>/approve"><button class="btn btn-sm btn-primary">Aktivasi</button></form><form method="POST" action="/tutor/aktivasi/<%=u.id%>/reject"><button class="btn btn-sm btn-danger">Tolak</button></form></td></tr><%})%><%if(!pending.length){%><tr><td colspan="6" class="text-muted text-center">Tidak ada yang menunggu.</td></tr><%}%></tbody></table>