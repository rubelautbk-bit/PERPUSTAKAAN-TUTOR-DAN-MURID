<div class="page-header">
  <div><h1><%= t('tutor.dashboardTitle') %></h1><p class="subtitle"><%= t('tutor.greeting', { name: user.name }) %></p></div>
</div>

<div class="stat-grid">
  <div class="stat"><div class="label"><%= t('tutor.statClasses') %></div><div class="value"><%= s.kelas %></div></div>
  <div class="stat blue"><div class="label"><%= t('tutor.statStudents') %></div><div class="value"><%= s.murid %></div></div>
  <div class="stat accent"><div class="label"><%= t('tutor.statMaterials') %></div><div class="value"><%= s.materi %></div></div>
  <div class="stat"><div class="label"><%= t('tutor.statRecs') %></div><div class="value"><%= s.rekomendasi %></div></div>
  <div class="stat red"><div class="label"><%= t('tutor.statQuizzes') %></div><div class="value"><%= s.quiz %></div></div>
</div>

<div class="grid-2">
  <div class="card">
    <div class="page-header">
      <h3 style="margin:0;"><%= t('tutor.myClasses') %></h3>
      <a href="/tutor/kelas" class="btn btn-sm btn-secondary"><%= t('common.seeAll') %></a>
    </div>
    <% kelasList.forEach(k => { %>
      <div style="padding:10px 0; border-bottom:1px solid var(--border);">
        <a href="/tutor/kelas/<%= k.id %>" style="font-weight:600; color:var(--text);"><%= k.nama %></a>
        <div class="text-muted" style="font-size:0.85rem;"><%= t('tutor.classCode') %>: <%= k.kode %> &middot; <%= k.jumlah %> <%= t('tutor.studentsCount') %></div>
      </div>
    <% }) %>
    <% if (kelasList.length === 0) { %><p class="text-muted"><%= t('tutor.noClasses') %></p><% } %>
  </div>

  <div class="card">
    <div class="page-header">
      <h3 style="margin:0;"><%= t('tutor.recentMaterials') %></h3>
      <a href="/tutor/materi" class="btn btn-sm btn-secondary"><%= t('common.seeAll') %></a>
    </div>
    <% materiTerbaru.forEach(m => { %>
      <div style="padding:10px 0; border-bottom:1px solid var(--border);">
        <span class="badge"><%= m.tipe %></span>
        <strong style="margin-left:6px;"><%= m.judul %></strong>
        <div class="text-muted" style="font-size:0.85rem;"><%= m.kelas_nama || t('tutor.public') %></div>
      </div>
    <% }) %>
  </div>
</div>
