<div class="page-header"><h1>Dashboard Tutor</h1><p class="subtitle">Halo, <%=user.name%>!</p></div><div class="stat-grid"><div class="stat"><div class="label">Kelas</div><div class="value"><%=s.kelas%></div></div><div class="stat blue"><div class="label">Murid</div><div class="value"><%=s.murid%></div></div><div class="stat accent"><div class="label">Materi</div><div class="value"><%=s.materi%></div></div><div class="stat"><div class="label">Ujian</div><div class="value"><%=s.ujian%></div></div><div class="stat red"><div class="label">Menunggu Aktivasi</div><div class="value"><%=s.pending%></div></div></div><div class="card"><h3>Kelas Saya</h3><%kelasList.forEach(k=>{%><div style="padding:8px 0;border-bottom:1px solid var(--border);"><a href="/tutor/kelas/<%=k.id%>" style="font-weight:600;color:var(--text)"><%=k.nama%></a><div class="text-muted" style="font-size:0.85rem">Kode: <%=k.kode%> | <%=k.jumlah%> murid</div></div><%})%></div>