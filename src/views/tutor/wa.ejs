<div class="page-header">
  <div>
    <h1>WhatsApp Gateway</h1>
    <p class="subtitle">Kirim notifikasi massal ke murid/kontak via WhatsApp</p>
  </div>
</div>

<div class="card" style="background:#fff3cd;color:#856404;border-left:4px solid #f4a623;padding:12px;">
  <strong>&#9432; Info:</strong> Setiap pesan otomatis ditambahkan footnote <em>"E-Library Rubela Indonesia"</em>. Gateway: Fonnte.
</div>

<!-- TABS -->
<div class="card" style="padding:6px; display:flex; gap:4px; flex-wrap:wrap;">
  <button class="btn btn-sm tab-btn active" data-tab="kirim">Kirim Pesan</button>
  <button class="btn btn-sm tab-btn" data-tab="kontak">Kontak (<%= kontak.length %>)</button>
  <button class="btn btn-sm tab-btn" data-tab="log">Log Pengiriman</button>
</div>

<!-- TAB: KIRIM -->
<div class="tab-content" data-tab="kirim">
  <div class="card">
    <h3>Kirim Pesan WhatsApp</h3>
    <form method="POST" action="/tutor/wa/kirim">
      <div class="form-group">
        <label>Target Pengiriman</label>
        <select name="target_type" class="form-control" id="targetType" onchange="toggleTarget()">
          <option value="single">Kirim ke 1 nomor</option>
          <option value="grup">Kirim ke 1 grup kontak</option>
          <option value="all_kontak">Kirim ke semua kontak</option>
        </select>
      </div>
      <div class="form-group" id="singleBox">
        <label>Nomor WhatsApp (format: 08xxx atau 62xxx)</label>
        <input type="text" name="phone" class="form-control" placeholder="08123456789"/>
      </div>
      <div class="form-group" id="grupBox" style="display:none;">
        <label>Pilih Grup</label>
        <select name="grup" class="form-control">
          <% grups.forEach(function(g) { %>
            <option value="<%= g %>"><%= g %></option>
          <% }) %>
          <% if (grups.length === 0) { %><option>-- Tidak ada grup --</option><% } %>
        </select>
      </div>
      <div class="form-group">
        <label>Pesan</label>
        <textarea name="pesan" class="form-control" rows="5" required placeholder="Tulis pesan di sini..."></textarea>
      </div>
      <button class="btn btn-primary">Kirim Pesan</button>
    </form>
  </div>
</div>

<!-- TAB: KONTAK -->
<div class="tab-content" data-tab="kontak" style="display:none;">
  <div class="grid-2">
    <div class="card">
      <h3>Tambah Kontak</h3>
      <form method="POST" action="/tutor/wa/kontak">
        <div class="form-group"><label>Nama</label><input name="nama" class="form-control" required/></div>
        <div class="form-group"><label>No. WhatsApp</label><input name="phone" class="form-control" placeholder="08xxx" required/></div>
        <div class="form-group"><label>Grup (opsional)</label><input name="grup" class="form-control" placeholder="Murid PU, Orangtua, dll"/></div>
        <div class="form-group"><label>Catatan</label><textarea name="catatan" class="form-control" rows="2"></textarea></div>
        <button class="btn btn-primary">Tambah</button>
      </form>
      <hr style="margin:16px 0;"/>
      <h4>Import / Export</h4>
      <form method="POST" action="/tutor/wa/kontak/import" enctype="multipart/form-data" class="row-flex">
        <input type="file" name="file" accept=".xlsx,.xls,.csv" class="form-control" required/>
        <button class="btn btn-primary">Import</button>
      </form>
      <p class="text-muted" style="font-size:0.82rem; margin-top:6px;">Kolom: nama, phone, grup, catatan</p>
      <a href="/tutor/wa/kontak/export.xlsx" class="btn btn-secondary mt-2">&#128229; Export Excel</a>
    </div>
    <div class="card">
      <h3>Daftar Kontak</h3>
      <table class="tbl">
        <thead><tr><th>Nama</th><th>Phone</th><th>Grup</th><th></th></tr></thead>
        <tbody>
          <% kontak.forEach(function(k) { %>
            <tr>
              <td><%= k.nama %></td>
              <td><code><%= k.phone %></code></td>
              <td><span class="badge"><%= k.grup || '-' %></span></td>
              <td>
                <form method="POST" action="/tutor/wa/kontak/<%= k.id %>?_method=DELETE" onsubmit="return confirm('Hapus?')">
                  <button class="btn btn-sm btn-danger">X</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (kontak.length === 0) { %>
            <tr><td colspan="4" class="text-muted text-center">Belum ada kontak.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- TAB: LOG -->
<div class="tab-content" data-tab="log" style="display:none;">
  <div class="card">
    <h3>Log Pengiriman (50 terakhir)</h3>
    <table class="tbl">
      <thead><tr><th>Waktu</th><th>Penerima</th><th>Pesan</th><th>Status</th><th>Oleh</th></tr></thead>
      <tbody>
        <% wa_logs.forEach(function(l) { %>
          <tr>
            <td><%= new Date(l.created_at).toLocaleString('id-ID') %></td>
            <td><code><%= l.phone %></code></td>
            <td style="max-width:300px;"><%= l.pesan.substring(0, 80) %><%= l.pesan.length>80?'...':'' %></td>
            <td><span class="badge <%= l.status==='sent'?'':'red' %>"><%= l.status %></span></td>
            <td><%= l.sender || '-' %></td>
          </tr>
        <% }) %>
        <% if (wa_logs.length === 0) { %>
          <tr><td colspan="5" class="text-muted text-center">Belum ada pengiriman.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
function toggleTarget() {
  var t = document.getElementById('targetType').value;
  document.getElementById('singleBox').style.display = (t==='single'?'':'none');
  document.getElementById('grupBox').style.display = (t==='grup'?'':'none');
}
toggleTarget();

document.querySelectorAll('.tab-btn').forEach(function(b) {
  b.addEventListener('click', function() {
    var tab = this.dataset.tab;
    document.querySelectorAll('.tab-btn').forEach(function(x){ x.classList.remove('active'); });
    this.classList.add('active');
    document.querySelectorAll('.tab-content').forEach(function(c) {
      c.style.display = (c.dataset.tab === tab) ? '' : 'none';
    });
  });
});
</script>
