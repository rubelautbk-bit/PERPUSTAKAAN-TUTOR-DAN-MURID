<div class="book-detail card">
  <div>
    <div class="cover-lg"><%= buku.judul %></div>
    <div style="display:grid; gap:8px; margin-top:16px;">
      <% if (user && user.role === 'murid') { %>
        <form method="POST" action="/murid/pinjam/<%= buku.id %>">
          <button class="btn btn-primary btn-block" <%= buku.stok_tersedia === 0 ? 'disabled' : '' %>>Pinjam Buku</button>
        </form>
        <form method="POST" action="/murid/wishlist/<%= buku.id %>">
          <button class="btn btn-secondary btn-block">+ Wishlist</button>
        </form>
        <% if (buku.file_pdf) { %>
          <a href="/uploads/<%= buku.file_pdf %>" target="_blank" class="btn btn-warning btn-block">Baca Online</a>
        <% } %>
      <% } else if (!user) { %>
        <a href="/auth/login" class="btn btn-primary btn-block">Login untuk Meminjam</a>
      <% } %>
    </div>
  </div>

  <div>
    <span class="badge"><%= buku.kategori_nama || 'Umum' %></span>
    <h1 style="margin:8px 0 4px;"><%= buku.judul %></h1>
    <p class="text-muted" style="margin:0;">oleh <strong><%= buku.penulis %></strong> &middot; <%= buku.penerbit %></p>

    <div class="row-flex mt-2">
      <div><span class="rating-star">&#9733;</span> <strong><%= buku.rating %></strong> (<%= buku.jumlah_rating %> ulasan)</div>
      <div><%= buku.dibaca %> pembaca</div>
      <% if (buku.stok_tersedia > 0) { %>
        <span class="badge">Tersedia: <%= buku.stok_tersedia %>/<%= buku.stok %></span>
      <% } else { %>
        <span class="badge red">Habis dipinjam</span>
      <% } %>
    </div>

    <h4 class="mt-3">Sinopsis</h4>
    <p><%= buku.sinopsis || 'Belum ada sinopsis.' %></p>

    <h4>Detail</h4>
    <table class="tbl">
      <tr><td><strong>Tahun Terbit</strong></td><td><%= buku.tahun %></td></tr>
      <tr><td><strong>Jumlah Halaman</strong></td><td><%= buku.jumlah_halaman %></td></tr>
      <tr><td><strong>Bahasa</strong></td><td><%= buku.bahasa %></td></tr>
      <tr><td><strong>ISBN</strong></td><td><%= buku.isbn || '-' %></td></tr>
      <tr><td><strong>Penerbit</strong></td><td><%= buku.penerbit %></td></tr>
    </table>

    <h4 class="mt-3">Ulasan Pembaca</h4>
    <% if (user && user.role === 'murid') { %>
      <form method="POST" action="/murid/rating/<%= buku.id %>" class="card" style="background:var(--bg); padding:14px;">
        <div class="form-row">
          <div class="form-group">
            <label>Rating (1-5)</label>
            <select name="nilai" class="form-control" required>
              <option value="5">&#9733;&#9733;&#9733;&#9733;&#9733; - Sempurna</option>
              <option value="4">&#9733;&#9733;&#9733;&#9733; - Bagus</option>
              <option value="3">&#9733;&#9733;&#9733; - Cukup</option>
              <option value="2">&#9733;&#9733; - Kurang</option>
              <option value="1">&#9733; - Buruk</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Ulasan</label>
          <textarea name="ulasan" class="form-control" placeholder="Bagaimana pendapatmu tentang buku ini?" required></textarea>
        </div>
        <button class="btn btn-primary">Kirim Ulasan</button>
      </form>
    <% } %>

    <% if (ulasan.length === 0) { %>
      <p class="text-muted">Belum ada ulasan. Jadilah yang pertama!</p>
    <% } else { %>
      <% ulasan.forEach(r => { %>
        <div style="padding:12px 0; border-bottom:1px solid var(--border);">
          <div class="row-flex" style="justify-content:space-between;">
            <strong><%= r.name %></strong>
            <span class="rating-star">
              <% for (let i=0;i<r.nilai;i++) { %>&#9733;<% } %>
            </span>
          </div>
          <p style="margin:4px 0 0;"><%= r.ulasan %></p>
          <div class="text-muted" style="font-size:0.8rem;"><%= new Date(r.created_at).toLocaleDateString('id-ID') %></div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<% if (rekomendasi.length > 0) { %>
  <div class="card mt-3">
    <h3>Buku Sejenis</h3>
    <div class="book-grid">
      <% rekomendasi.forEach(b => { %>
        <a href="/buku/<%= b.id %>" class="book-card">
          <div class="book-cover"><%= b.judul %></div>
          <div class="book-info">
            <div class="title"><%= b.judul %></div>
            <div class="author"><%= b.penulis %></div>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
<% } %>
