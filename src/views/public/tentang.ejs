<section class="hero" style="padding:50px 30px;">
  <h1><%= t('about.title') %></h1>
  <p><%= t('about.subtitle') %></p>
</section>

<div class="grid-2">
  <div class="card">
    <h3><%= t('about.vision') %></h3>
    <p><%= t('about.visionDesc') %></p>
  </div>
  <div class="card">
    <h3><%= t('about.mission') %></h3>
    <ul>
      <li><%= t('about.missionL1') %></li>
      <li><%= t('about.missionL2') %></li>
      <li><%= t('about.missionL3') %></li>
      <li><%= t('about.missionL4') %></li>
    </ul>
  </div>
</div>

<div class="card mt-3">
  <h3><%= t('about.features') %></h3>
  <div class="grid-3">
    <div>
      <h4><%= t('about.feat1Title') %></h4>
      <p class="text-muted"><%= t('about.feat1Desc') %></p>
    </div>
    <div>
      <h4><%= t('about.feat2Title') %></h4>
      <p class="text-muted"><%= t('about.feat2Desc') %></p>
    </div>
    <div>
      <h4><%= t('about.feat3Title') %></h4>
      <p class="text-muted"><%= t('about.feat3Desc') %></p>
    </div>
    <div>
      <h4><%= t('about.feat4Title') %></h4>
      <p class="text-muted"><%= t('about.feat4Desc') %></p>
    </div>
    <div>
      <h4><%= t('about.feat5Title') %></h4>
      <p class="text-muted"><%= t('about.feat5Desc') %></p>
    </div>
    <div>
      <h4><%= t('about.feat6Title') %></h4>
      <p class="text-muted"><%= t('about.feat6Desc') %></p>
    </div>
  </div>
</div>
