<div class="page-header"><h1>Manajemen Kelas</h1></div><div class="card"><h3>Buat Kelas</h3><form method="POST" action="/admin/kelas"><div class="form-row"><div class="form-group"><label>Nama/Subtest</label><select name="nama" class="form-control"><option>Penalaran Umum (PU)</option><option>Pengetahuan dan Pemahaman Umum (PPU)</option><option>Kemampuan Memahami Bacaan dan Menulis (PBM)</option><option>Pengetahuan Kuantitatif (PK)</option><option>Literasi dalam Bahasa Indonesia</option><option>Literasi dalam Bahasa Inggris</option><option>Penalaran Matematika</option><option value="">-- Lainnya (ketik manual) --</option></select></div><div class="form-group"><label>Atau ketik nama manual</label><input name="subtest" class="form-control" placeholder="Kode subtest"/></div><div class="form-group"><label>Kode Unik</label><input name="kode" class="form-control" required/></div><div class="form-group"><label>Tutor</label><select name="tutor_id" class="form-control"><% tutors.forEach(t=>{ %><option value="<%= t.id %>"><%= t.name %></option><% }) %></select></div></div><div class="form-group"><label>Deskripsi</label><textarea name="deskripsi" class="form-control"></textarea></div><button class="btn btn-primary">Buat Kelas</button></form></div><table class="tbl"><thead><tr><th>Nama</th><th>Kode</th><th>Tutor</th><th>Murid</th><th>Aksi</th></tr></thead><tbody><% kelas.forEach(k=>{ %><tr><td><a href="/admin/kelas/<%= k.id %>"><strong><%= k.nama %></strong></a></td><td><code><%= k.kode %></code></td><td><%= k.tutor_name %></td><td><%= k.jumlah %></td><td><a href="/admin/kelas/<%= k.id %>" class="btn btn-sm btn-secondary">Detail</a></td></tr><% }) %></tbody></table>