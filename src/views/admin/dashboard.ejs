<div class="page-header">
  <div>
    <h1><%= t('admin.dashboardTitle') %></h1>
    <p class="subtitle"><%= t('admin.dashboardSubtitle') %></p>
  </div>
  <div class="row-flex">
    <a href="/admin/buku/new" class="btn btn-primary"><%= t('admin.addBook') %></a>
    <a href="/admin/pengumuman" class="btn btn-secondary"><%= t('admin.addAnnouncement') %></a>
  </div>
</div>

<div class="stat-grid">
  <div class="stat"><div class="label"><%= t('admin.statBooks') %></div><div class="value"><%= s.totalBuku %></div></div>
  <div class="stat accent"><div class="label"><%= t('admin.statUsers') %></div><div class="value"><%= s.totalUser %></div></div>
  <div class="stat blue"><div class="label"><%= t('admin.statStudents') %></div><div class="value"><%= s.totalMurid %></div></div>
  <div class="stat blue"><div class="label"><%= t('admin.statTutors') %></div><div class="value"><%= s.totalTutor %></div></div>
  <div class="stat"><div class="label"><%= t('admin.statBorrowing') %></div><div class="value"><%= s.totalPinjam %></div></div>
  <div class="stat accent"><div class="label"><%= t('admin.statPending') %></div><div class="value"><%= s.totalMenunggu %></div></div>
  <div class="stat red"><div class="label"><%= t('admin.statFines') %></div><div class="value">Rp <%= s.totalDenda.toLocaleString(lang === 'en' ? 'en-US' : 'id-ID') %></div></div>
</div>

<div class="grid-2">
  <div class="card">
    <h3><%= t('admin.popularBooks') %></h3>
    <div class="bar-chart">
      <% const max = Math.max(1, ...bukuPopuler.map(b=>b.dibaca)); %>
      <% bukuPopuler.forEach(b => { %>
        <div class="bar-row">
          <div style="font-size:0.9rem;"><%= b.judul %></div>
          <div class="bar-track"><div class="bar-fill" style="width: <%= (b.dibaca/max*100).toFixed(0) %>%"></div></div>
          <div class="text-muted text-center"><%= b.dibaca %></div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="card">
    <h3><%= t('admin.activeStudents') %></h3>
    <table class="tbl">
      <thead><tr><th><%= t('common.name') %></th><th><%= t('admin.totalBorrows') %></th></tr></thead>
      <tbody>
        <% userAktif.forEach(u => { %>
          <tr><td><%= u.name %></td><td><%= u.total %></td></tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="grid-2 mt-3">
  <div class="card">
    <h3><%= t('admin.activeTutors') %></h3>
    <table class="tbl">
      <thead><tr><th><%= t('common.name') %></th><th><%= t('sidebar.classes') %></th><th><%= t('sidebar.materials') %></th></tr></thead>
      <tbody>
        <% tutorAktif.forEach(tt => { %>
          <tr><td><%= tt.name %></td><td><%= tt.kelas %></td><td><%= tt.materi %></td></tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h3><%= t('admin.recentBorrows') %></h3>
    <table class="tbl">
      <thead><tr><th><%= t('role.murid') %></th><th><%= t('book.title') %></th><th><%= t('common.status') %></th></tr></thead>
      <tbody>
        <% peminjamanTerbaru.forEach(p => { %>
          <tr>
            <td><%= p.user_name %></td>
            <td><%= p.judul %></td>
            <td><span class="badge <%= p.status==='menunggu' ? 'warn' : p.status==='ditolak' ? 'red' : p.status==='dikembalikan' ? 'gray' : '' %>"><%= p.status %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
