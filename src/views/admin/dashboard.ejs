<div class="page-header"><h1>Dashboard Admin</h1></div><div class="stat-grid"><div class="stat"><div class="label">Total Buku</div><div class="value"><%= s.totalBuku %></div></div><div class="stat accent"><div class="label">Total User</div><div class="value"><%= s.totalUser %></div></div><div class="stat blue"><div class="label">Murid</div><div class="value"><%= s.totalMurid %></div></div><div class="stat"><div class="label">Tutor</div><div class="value"><%= s.totalTutor %></div></div><div class="stat red"><div class="label">Sedang Dipinjam</div><div class="value"><%= s.totalPinjam %></div></div><div class="stat accent"><div class="label">Menunggu Aktivasi</div><div class="value"><%= s.totalPending %></div></div><div class="stat"><div class="label">Total Denda</div><div class="value">Rp <%= s.totalDenda.toLocaleString() %></div></div><div class="stat blue"><div class="label">Kelas</div><div class="value"><%= s.totalKelas %></div></div></div><% if(pendingUsers.length>0) { %><div class="card"><h3>User Menunggu Aktivasi</h3><% pendingUsers.forEach(u=>{ %><div style="padding:8px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;"><div><strong><%= u.name %></strong> (<%= u.role %>) - <%= u.email %></div><form method="POST" action="/admin/users/<%= u.id %>/activate"><button class="btn btn-sm btn-primary">Aktivasi</button></form></div><% }) %></div><% } %><div class="card"><h3>Peminjaman Terbaru</h3><table class="tbl"><thead><tr><th>Murid</th><th>Buku</th><th>Status</th></tr></thead><tbody><% peminjamanTerbaru.forEach(p=>{ %><tr><td><%= p.user_name %></td><td><%= p.judul %></td><td><span class="badge <%= p.status==='menunggu'?'warn':''%>"><%= p.status %></span></td></tr><% }) %></tbody></table></div>