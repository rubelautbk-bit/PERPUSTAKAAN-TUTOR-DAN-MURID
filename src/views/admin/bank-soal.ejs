<div class="page-header"><h1>Bank Soal</h1><div class="row-flex"><a href="/admin/bank-soal/export.xlsx<%= currentSubtest?'?subtest='+currentSubtest:''%>" class="btn btn-secondary">Export</a><a href="/admin/bank-soal/tambah?subtest=<%= currentSubtest %>" class="btn btn-primary">+ Tambah Soal</a></div></div><div class="row-flex mb-2"><% subtests.forEach(st=>{ %><a href="/admin/bank-soal?subtest=<%= st %>" class="btn btn-sm <%= currentSubtest===st?'btn-primary':'btn-secondary'%>"><%= st %></a><% }) %><a href="/admin/bank-soal" class="btn btn-sm btn-secondary">Semua</a></div><% if(currentSubtest) { %><form method="POST" action="/admin/bank-soal/bulk-poin" class="card" style="padding:10px;"><input type="hidden" name="subtest" value="<%= currentSubtest %>"/><div class="row-flex"><label>Ubah poin semua soal <%= currentSubtest %>:</label><input type="number" name="poin" class="form-control" style="width:80px" value="1" min="1"/><button class="btn btn-sm btn-primary">Set</button></div></form><% } %><table class="tbl"><thead><tr><th>#</th><th>Soal</th><th>Tipe</th><th>Subtest</th><th>Poin</th><th>Aksi</th></tr></thead><tbody><% soal.forEach((s,i)=>{ %><tr><td><%= i+1 %></td><td style="max-width:400px;"><%- s.soal.substring(0,100) %><%= s.soal.length>100?'...':''%></td><td><span class="badge"><%= s.tipe %></span></td><td><%= s.subtest %></td><td><%= s.poin %></td><td><form method="POST" action="/admin/bank-soal/<%= s.id %>?_method=DELETE" style="display:inline"><button class="btn btn-sm btn-danger">X</button></form></td></tr><% }) %></tbody></table>