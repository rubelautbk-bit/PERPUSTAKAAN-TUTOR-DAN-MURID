<div class="page-header"><h1>CBT / Ujian / Kuis</h1><a href="/admin/ujian/new" class="btn btn-primary">+ Buat Ujian</a></div><table class="tbl"><thead><tr><th>Judul</th><th>Tipe</th><th>Soal</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% ujian.forEach(u=>{ %><tr><td><strong><%= u.judul %></strong><div class="text-muted" style="font-size:0.82rem;"><%= u.deskripsi||'-' %></div></td><td><span class="badge"><%= u.tipe %></span></td><td><%= u.jml_soal %></td><td><span class="badge <%= u.status==='aktif'?'':'warn'%>"><%= u.status %></span></td><td class="row-flex"><a href="/admin/ujian/<%= u.id %>/soal" class="btn btn-sm btn-secondary">Soal</a><a href="/admin/ujian/<%= u.id %>/hasil" class="btn btn-sm btn-secondary">Hasil</a><% if(u.status==='draft') { %><form method="POST" action="/admin/ujian/<%= u.id %>/publish"><button class="btn btn-sm btn-primary">Publish</button></form><% } %></td></tr><% }) %></tbody></table>