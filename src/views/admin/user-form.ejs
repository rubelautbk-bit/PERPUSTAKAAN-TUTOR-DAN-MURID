<div class="page-header">
  <h1><%= u ? 'Edit User' : 'Tambah User' %></h1>
  <a href="/admin/users" class="btn btn-secondary">Kembali</a>
</div>

<form method="POST" action="<%= u ? '/admin/users/' + u.id + '?_method=PUT' : '/admin/users' %>" class="card">
  <div class="form-row">
    <div class="form-group">
      <label>Nama</label>
      <input type="text" name="name" class="form-control" value="<%= u ? u.name : '' %>" required />
    </div>
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" class="form-control" value="<%= u ? u.email : '' %>" required />
    </div>
    <div class="form-group">
      <label>No HP</label>
      <input type="text" name="phone" class="form-control" value="<%= u ? (u.phone||'') : '' %>" />
    </div>
    <div class="form-group">
      <label>Role</label>
      <select name="role" class="form-control">
        <% ['admin','tutor','murid'].forEach(r => { %>
          <option value="<%= r %>" <%= u && u.role===r ? 'selected' : '' %>><%= r %></option>
        <% }) %>
      </select>
    </div>
    <% if (u) { %>
    <div class="form-group">
      <label>Status</label>
      <select name="status" class="form-control">
        <option value="active" <%= u.status==='active' ? 'selected' : '' %>>Active</option>
        <option value="suspended" <%= u.status==='suspended' ? 'selected' : '' %>>Suspended</option>
      </select>
    </div>
    <% } %>
    <div class="form-group">
      <label>Password <% if (u) { %><span class="text-muted">(kosongkan jika tidak diubah)</span><% } %></label>
      <input type="password" name="password" class="form-control" <%= u ? '' : 'required' %> />
    </div>
  </div>
  <button class="btn btn-primary"><%= u ? 'Simpan Perubahan' : 'Tambah User' %></button>
</form>
