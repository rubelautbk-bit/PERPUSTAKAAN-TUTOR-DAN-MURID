<div class="page-header"><h1>Galeri</h1></div><div class="grid-2"><div class="card"><h3>Upload</h3><form method="POST" action="/admin/galeri" enctype="multipart/form-data"><div class="form-group"><label>Judul</label><input name="judul" class="form-control" required/></div><div class="form-group"><label>File</label><input type="file" name="file" class="form-control"/></div><div class="form-group"><label>Atau URL</label><input name="file_url" class="form-control" placeholder="https://..."/></div><button class="btn btn-primary">Upload</button></form></div><div class="card"><h3>Koleksi</h3><div class="book-grid"><% list.forEach(g=>{ %><div class="book-card"><div class="book-cover" style="font-size:0.8rem;"><%= g.judul %></div><div class="book-info"><div class="title"><%= g.judul %></div><form method="POST" action="/admin/galeri/<%= g.id %>?_method=DELETE"><button class="btn btn-sm btn-danger">X</button></form></div></div><% }) %></div></div></div>