<div class="page-header"><h1>Usulan Buku</h1></div><table class="tbl"><thead><tr><th>Judul</th><th>Pencipta</th><th>Tahun</th><th>Pengusul</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% list.forEach(u=>{ %><tr><td><strong><%= u.judul %></strong><% if(u.link) { %> <a href="<%= u.link %>" target="_blank">Link</a><% } %><% if(u.file) { %> <a href="/uploads/<%= u.file %>" target="_blank">File</a><% } %></td><td><%= u.pencipta||'-' %></td><td><%= u.tahun_terbit||'-' %></td><td><%= u.user_name %></td><td><span class="badge <%= u.status==='disetujui'?'':(u.status==='ditolak'?'red':'warn')%>"><%= u.status %></span></td><td class="row-flex"><% if(u.status==='pending') { %><form method="POST" action="/admin/usulan/<%= u.id %>/approve"><button class="btn btn-sm btn-primary">Setuju</button></form><form method="POST" action="/admin/usulan/<%= u.id %>/reject"><button class="btn btn-sm btn-danger">Tolak</button></form><% } %></td></tr><% }) %></tbody></table>