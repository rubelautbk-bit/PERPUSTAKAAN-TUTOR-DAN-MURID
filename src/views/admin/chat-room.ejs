<div class="page-header"><h1><%=room?room.nama||'Chat':'Chat'%></h1><a href="/admin/chat" class="btn btn-secondary">&larr; Kembali</a></div><div class="card" id="chatBox" style="max-height:500px;overflow-y:auto;padding:16px"><%messages.forEach(m=>{%><div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong><%=m.name%></strong> <span class="text-muted" style="font-size:0.8rem"><%=new Date(m.created_at).toLocaleString("id-ID")%></span><div><%=m.pesan%></div></div><%})%><%if(!messages.length){%><p class="text-muted">Belum ada pesan. Mulai percakapan!</p><%}%></div><form id="chatForm" style="display:flex;gap:8px;margin-top:12px"><input id="chatInput" class="form-control" placeholder="Ketik pesan..." autocomplete="off"/><button class="btn btn-primary">Kirim</button></form><script src="/socket.io/socket.io.js"></script><script>const socket=io();const roomId=<%=room?room.id:0%>;const userId=<%=user.id%>;const userName="<%=user.name%>";socket.emit("join-room",roomId);socket.on("new-message",d=>{const box=document.getElementById("chatBox");box.innerHTML+='<div style="padding:6px 0;border-bottom:1px solid var(--border)"><strong>'+d.name+'</strong> <span class="text-muted" style="font-size:0.8rem">'+new Date(d.created_at).toLocaleString("id-ID")+'</span><div>'+d.pesan+'</div></div>';box.scrollTop=box.scrollHeight;});document.getElementById("chatForm").onsubmit=e=>{e.preventDefault();const input=document.getElementById("chatInput");if(!input.value.trim())return;socket.emit("chat-message",{roomId,userId,userName,pesan:input.value});input.value="";};document.getElementById("chatBox").scrollTop=document.getElementById("chatBox").scrollHeight;</script>
