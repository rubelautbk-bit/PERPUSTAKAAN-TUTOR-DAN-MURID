<div class="page-header"><h1>Buat Ujian/Kuis</h1></div><form method="POST" action="/admin/ujian" class="card"><div class="form-row"><div class="form-group"><label>Judul</label><input name="judul" class="form-control" required/></div><div class="form-group"><label>Tipe</label><select name="tipe" class="form-control"><option value="kuis">Kuis</option><option value="ujian">Ujian</option><option value="cbt">CBT</option><option value="latihan">Latihan</option></select></div><div class="form-group"><label>Kelas (opsional)</label><select name="kelas_id" class="form-control"><option value="">Semua</option><% kelas.forEach(k=>{ %><option value="<%= k.id %>"><%= k.nama %></option><% }) %></select></div><div class="form-group"><label>Durasi (menit)</label><input type="number" name="durasi_menit" class="form-control" value="60"/></div></div><div class="form-row"><div class="form-group"><label>Waktu Mulai</label><input type="datetime-local" name="waktu_mulai" class="form-control"/></div><div class="form-group"><label>Waktu Selesai</label><input type="datetime-local" name="waktu_selesai" class="form-control"/></div></div><div class="form-row"><div class="form-group"><label><input type="checkbox" name="acak_soal" checked/> Acak Soal</label></div><div class="form-group"><label><input type="checkbox" name="acak_opsi" checked/> Acak Opsi</label></div><div class="form-group"><label><input type="checkbox" name="anti_cheat" checked/> Anti Cheat</label></div><div class="form-group"><label>Poin Negatif</label><input type="number" name="poin_negatif" class="form-control" value="0" step="0.1"/></div></div><div class="form-group"><label>Deskripsi</label><textarea name="deskripsi" class="form-control" rows="3"></textarea></div><button class="btn btn-primary">Buat Ujian</button></form>