<div class="page-header">
  <h1><%= b ? 'Edit Buku' : 'Tambah Buku' %></h1>
  <a href="/admin/buku" class="btn btn-secondary">Kembali</a>
</div>

<form method="POST" action="<%= b ? '/admin/buku/' + b.id + '?_method=PUT' : '/admin/buku' %>" enctype="multipart/form-data" class="card">
  <div class="form-row">
    <div class="form-group">
      <label>Judul *</label>
      <input type="text" name="judul" class="form-control" value="<%= b ? b.judul : '' %>" required />
    </div>
    <div class="form-group">
      <label>Penulis</label>
      <input type="text" name="penulis" class="form-control" value="<%= b ? (b.penulis||'') : '' %>" />
    </div>
    <div class="form-group">
      <label>Penerbit</label>
      <input type="text" name="penerbit" class="form-control" value="<%= b ? (b.penerbit||'') : '' %>" />
    </div>
    <div class="form-group">
      <label>Tahun</label>
      <input type="number" name="tahun" class="form-control" value="<%= b ? (b.tahun||'') : '' %>" />
    </div>
    <div class="form-group">
      <label>ISBN</label>
      <input type="text" name="isbn" class="form-control" value="<%= b ? (b.isbn||'') : '' %>" />
    </div>
    <div class="form-group">
      <label>Bahasa</label>
      <select name="bahasa" class="form-control">
        <option value="Indonesia" <%= b && b.bahasa==='Indonesia' ? 'selected' : '' %>>Indonesia</option>
        <option value="Inggris" <%= b && b.bahasa==='Inggris' ? 'selected' : '' %>>Inggris</option>
      </select>
    </div>
    <div class="form-group">
      <label>Kategori</label>
      <select name="kategori_id" class="form-control">
        <option value="">-- Pilih --</option>
        <% kategoriList.forEach(k => { %>
          <option value="<%= k.id %>" <%= b && b.kategori_id===k.id ? 'selected' : '' %>><%= k.nama %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>Jumlah Halaman</label>
      <input type="number" name="jumlah_halaman" class="form-control" value="<%= b ? (b.jumlah_halaman||0) : 0 %>" />
    </div>
    <div class="form-group">
      <label>Stok</label>
      <input type="number" name="stok" class="form-control" value="<%= b ? b.stok : 1 %>" min="1" />
    </div>
  </div>
  <div class="form-group">
    <label>Sinopsis</label>
    <textarea name="sinopsis" class="form-control" rows="4"><%= b ? (b.sinopsis||'') : '' %></textarea>
  </div>

  <div class="card" style="background:var(--brand-light); border:0; padding:14px;">
    <h4 style="margin:0 0 6px;">&#128640; Hemat Disk (Rekomendasi)</h4>
    <p class="text-muted" style="font-size:0.88rem; margin:0;">
      Daripada upload file PDF ke server (makan disk), <strong>gunakan URL eksternal</strong> dari
      Google Drive, Cloudinary, Supabase Storage, atau hosting gratis lainnya.
      <br/>
      Contoh Drive: <code>https://drive.google.com/file/d/ABC123/view?usp=sharing</code>
    </p>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>URL Cover (eksternal)</label>
      <input type="url" name="cover_url" class="form-control" value="<%= b ? (b.cover_url||'') : '' %>" placeholder="https://..." />
    </div>
    <div class="form-group">
      <label>URL PDF (eksternal)</label>
      <input type="url" name="pdf_url" class="form-control" value="<%= b ? (b.pdf_url||'') : '' %>" placeholder="https://... .pdf atau Drive share link" />
    </div>
  </div>

  <div class="row-flex mt-2" style="padding:8px 0;">
    <span class="text-muted">ATAU upload langsung ke server (tidak direkomendasikan):</span>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label>Cover (gambar)</label>
      <input type="file" name="cover" accept="image/*" class="form-control" />
      <% if (b && b.cover) { %><small>Saat ini: <a href="/uploads/<%= b.cover %>" target="_blank"><%= b.cover %></a></small><% } %>
    </div>
    <div class="form-group">
      <label>File PDF / ePub</label>
      <input type="file" name="file_pdf" accept=".pdf,.epub" class="form-control" />
      <% if (b && b.file_pdf) { %><small>Saat ini: <a href="/uploads/<%= b.file_pdf %>" target="_blank"><%= b.file_pdf %></a></small><% } %>
    </div>
  </div>

  <button class="btn btn-primary"><%= b ? 'Simpan Perubahan' : 'Tambah Buku' %></button>
</form>
