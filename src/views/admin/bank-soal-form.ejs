<div class="page-header"><h1>Tambah Soal</h1><a href="/admin/bank-soal" class="btn btn-secondary">Kembali</a></div><div class="card" style="background:var(--brand-light);border:0;padding:14px;margin-bottom:16px;"><strong>LaTeX Support:</strong> Gunakan <code>$...$</code> untuk inline math dan <code>891...891</code> untuk display math. Contoh: <code>$\frac{-b \pm \sqrt{D}}{2a}$</code></div><form method="POST" action="/admin/bank-soal" class="card"><div class="form-row"><div class="form-group"><label>Subtest</label><select name="subtest" class="form-control"><% subtests.forEach(st=>{ %><option value="<%= st %>" <%= subtest===st?'selected':'' %>><%= st %></option><% }) %></select></div><div class="form-group"><label>Tipe Soal</label><select name="tipe" class="form-control" id="tipe" onchange="toggleOpsi()"><option value="pg">Pilihan Ganda</option><option value="pg_kompleks">PG Kompleks (multi)</option><option value="benar_salah">Benar/Salah</option><option value="menjodohkan">Menjodohkan</option><option value="isian">Isian Singkat</option><option value="esai">Esai/Uraian</option><option value="drag_drop">Drag & Drop</option><option value="labeling">Pelabelan</option></select></div><div class="form-group"><label>Poin</label><input type="number" name="poin" class="form-control" value="1" min="1"/></div></div><div class="form-group"><label>Soal (HTML + LaTeX)</label><textarea name="soal" class="form-control" rows="6" required placeholder="Contoh: Jika ^2 + 5x + 6 = 0$, maka nilai $ adalah..."></textarea></div><div class="form-group" id="opsiGroup"><label>Opsi Jawaban (JSON array)</label><textarea name="opsi_json" class="form-control" rows="4" placeholder='["Opsi A","Opsi B","Opsi C","Opsi D"]'>["Opsi A","Opsi B","Opsi C","Opsi D"]</textarea></div><div class="form-group"><label>Jawaban Benar (JSON)</label><input name="jawaban_json" class="form-control" placeholder='"A" atau ["A","C"] untuk PG kompleks'/></div><div class="form-group"><label>Penjelasan (opsional)</label><textarea name="penjelasan" class="form-control" rows="3"></textarea></div><button class="btn btn-primary">Simpan Soal</button></form><script>function toggleOpsi(){var t=document.getElementById("tipe").value;document.getElementById("opsiGroup").style.display=["isian","esai"].includes(t)?"none":"block";}</script>