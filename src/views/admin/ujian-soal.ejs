<div class="page-header"><div><a href="/admin/ujian">&larr; Ujian</a><h1>Soal: <%= uj.judul %></h1></div></div><div class="grid-2"><div class="card"><h3>Pilih Soal dari Bank (<%= bankSoal.length %> tersedia)</h3><form method="POST" action="/admin/ujian/<%= uj.id %>/soal"><div style="max-height:400px;overflow-y:auto;"><label style="display:block;padding:6px;border-bottom:1px solid var(--border);cursor:pointer;"><input type="checkbox" onclick="this.closest('form').querySelectorAll('input[name=soal_ids]').forEach(c=>c.checked=this.checked)"/> <strong>Pilih Semua</strong></label><% bankSoal.forEach(s=>{ %><label style="display:block;padding:6px;cursor:pointer;"><input type="checkbox" name="soal_ids" value="<%= s.id %>"/> [<%= s.subtest %>] <%- s.soal.substring(0,80) %> (<%= s.tipe %>, <%= s.poin %>pt)</label><% }) %></div><button class="btn btn-primary mt-2">Tambahkan Terpilih</button></form></div><div class="card"><h3>Soal Terpilih (<%= soalTerpilih.length %>)</h3><% soalTerpilih.forEach((s,i)=>{ %><div style="padding:6px 0;border-bottom:1px solid var(--border);"><%= i+1 %>. [<%= s.subtest %>] <%- s.soal.substring(0,60) %> (<%= s.poin %>pt)</div><% }) %></div></div>