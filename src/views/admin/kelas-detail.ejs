<div class="page-header"><div><a href="/admin/kelas">&larr; Kelas</a><h1><%= kelas.nama %></h1><p class="subtitle">Kode: <strong><%= kelas.kode %></strong> | Tutor: <%= kelas.tutor_name %></p></div></div><div class="grid-2"><div class="card"><h3>Tambah Murid (Bulk)</h3><form method="POST" action="/admin/kelas/<%= kelas.id %>/members"><div style="max-height:300px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;padding:10px;"><label style="display:block;padding:6px;cursor:pointer;border-bottom:1px solid var(--border);"><input type="checkbox" onclick="this.closest('form').querySelectorAll('input[name=user_ids]').forEach(c=>c.checked=this.checked)"/> <strong>Pilih Semua</strong></label><% allMurid.forEach(m=>{ %><label style="display:block;padding:6px;cursor:pointer;"><input type="checkbox" name="user_ids" value="<%= m.id %>"/> <%= m.name %> (<%= m.email %>)</label><% }) %></div><button class="btn btn-primary mt-2">Tambahkan Terpilih</button></form></div><div class="card"><h3>Anggota (<%= members.length %>)</h3><% members.forEach(m=>{ %><div style="padding:6px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;"><span><%= m.name %> - <%= m.email %></span><form method="POST" action="/admin/kelas/<%= kelas.id %>/members/<%= m.id %>?_method=DELETE"><button class="btn btn-sm btn-danger">X</button></form></div><% }) %></div></div>