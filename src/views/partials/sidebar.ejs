<aside class="sidebar">
  <% if (user.role === 'admin') { %>
    <h6><%= t('sidebar.adminPanel') %></h6>
    <a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>"><%= t('sidebar.dashboard') %></a>
    <a href="/admin/users" class="<%= currentPath.startsWith('/admin/users') ? 'active' : '' %>"><%= t('sidebar.userMgmt') %></a>
    <a href="/admin/buku" class="<%= currentPath.startsWith('/admin/buku') ? 'active' : '' %>"><%= t('sidebar.bookMgmt') %></a>
    <a href="/admin/kategori" class="<%= currentPath.startsWith('/admin/kategori') ? 'active' : '' %>"><%= t('sidebar.categories') %></a>
    <a href="/admin/peminjaman" class="<%= currentPath.startsWith('/admin/peminjaman') ? 'active' : '' %>"><%= t('sidebar.borrows') %></a>
    <a href="/admin/denda" class="<%= currentPath.startsWith('/admin/denda') ? 'active' : '' %>"><%= t('sidebar.fines') %></a>
    <a href="/admin/pengumuman" class="<%= currentPath.startsWith('/admin/pengumuman') ? 'active' : '' %>"><%= t('sidebar.announcements') %></a>
    <a href="/admin/laporan" class="<%= currentPath.startsWith('/admin/laporan') ? 'active' : '' %>"><%= t('sidebar.reports') %></a>
    <a href="/admin/settings" class="<%= currentPath.startsWith('/admin/settings') ? 'active' : '' %>"><%= t('sidebar.settings') %></a>
  <% } else if (user.role === 'tutor') { %>
    <h6><%= t('sidebar.tutorPanel') %></h6>
    <a href="/tutor" class="<%= currentPath === '/tutor' ? 'active' : '' %>"><%= t('sidebar.dashboard') %></a>
    <a href="/tutor/kelas" class="<%= currentPath.startsWith('/tutor/kelas') ? 'active' : '' %>"><%= t('sidebar.classes') %></a>
    <a href="/tutor/murid" class="<%= currentPath.startsWith('/tutor/murid') ? 'active' : '' %>"><%= t('sidebar.students') %></a>
    <a href="/tutor/materi" class="<%= currentPath.startsWith('/tutor/materi') ? 'active' : '' %>"><%= t('sidebar.materials') %></a>
    <a href="/tutor/rekomendasi" class="<%= currentPath.startsWith('/tutor/rekomendasi') ? 'active' : '' %>"><%= t('sidebar.recommendations') %></a>
    <a href="/tutor/quiz" class="<%= currentPath.startsWith('/tutor/quiz') ? 'active' : '' %>"><%= t('sidebar.quizzes') %></a>
    <a href="/tutor/forum" class="<%= currentPath.startsWith('/tutor/forum') ? 'active' : '' %>"><%= t('sidebar.forum') %></a>
    <a href="/tutor/progress" class="<%= currentPath.startsWith('/tutor/progress') ? 'active' : '' %>"><%= t('sidebar.studentProgress') %></a>
  <% } else if (user.role === 'murid') { %>
    <h6><%= t('sidebar.studentMenu') %></h6>
    <a href="/murid" class="<%= currentPath === '/murid' ? 'active' : '' %>"><%= t('sidebar.dashboard') %></a>
    <a href="/katalog" class="<%= currentPath.startsWith('/katalog') ? 'active' : '' %>"><%= t('sidebar.searchBook') %></a>
    <a href="/murid/buku-saya" class="<%= currentPath.startsWith('/murid/buku-saya') ? 'active' : '' %>"><%= t('sidebar.myBooks') %></a>
    <a href="/murid/wishlist" class="<%= currentPath.startsWith('/murid/wishlist') ? 'active' : '' %>"><%= t('sidebar.wishlist') %></a>
    <a href="/murid/progress" class="<%= currentPath.startsWith('/murid/progress') ? 'active' : '' %>"><%= t('sidebar.progress') %></a>
    <a href="/murid/tugas" class="<%= currentPath.startsWith('/murid/tugas') ? 'active' : '' %>"><%= t('sidebar.tasks') %></a>
    <a href="/murid/leaderboard" class="<%= currentPath.startsWith('/murid/leaderboard') ? 'active' : '' %>">&#127942; <%= t('sidebar.leaderboard') %></a>
    <a href="/murid/forum" class="<%= currentPath.startsWith('/murid/forum') ? 'active' : '' %>"><%= t('sidebar.forum') %></a>
    <a href="/murid/notifikasi" class="<%= currentPath.startsWith('/murid/notifikasi') ? 'active' : '' %>"><%= t('sidebar.notifications') %></a>
    <a href="/murid/profile" class="<%= currentPath.startsWith('/murid/profile') ? 'active' : '' %>"><%= t('sidebar.profile') %></a>
  <% } %>
</aside>
