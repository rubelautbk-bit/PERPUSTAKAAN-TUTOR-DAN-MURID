<header class="topbar">
  <a href="/" class="brand">
    <span class="logo">RB</span>
    <span>Rubela Library</span>
  </a>

  <nav>
    <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Beranda</a>
    <a href="/katalog" class="<%= currentPath.startsWith('/katalog') ? 'active' : '' %>">Katalog</a>
    <a href="/pengumuman" class="<%= currentPath.startsWith('/pengumuman') ? 'active' : '' %>">Pengumuman</a>
    <a href="/tentang" class="<%= currentPath === '/tentang' ? 'active' : '' %>">Tentang</a>
  </nav>

  <div class="actions">
    <div class="lang-switch" style="display:flex; gap:4px; font-size:0.82rem;">
      <a href="/bahasa/id" class="<%= (user && user.bahasa === 'id') || !user ? 'active-lang' : '' %>" style="padding:4px 8px;">ID</a>
      <a href="/bahasa/en" class="<%= user && user.bahasa === 'en' ? 'active-lang' : '' %>" style="padding:4px 8px;">EN</a>
    </div>
    <button id="themeToggle" class="theme-toggle" title="Toggle tema">Tema</button>
    <% if (user) { %>
      <a href="/<%= user.role %>" class="btn btn-sm btn-secondary"><%= user.name.split(' ')[0] %></a>
      <a href="/auth/logout" class="btn btn-sm btn-primary">Keluar</a>
    <% } else { %>
      <a href="/auth/login" class="btn btn-sm btn-secondary">Masuk</a>
      <a href="/auth/register" class="btn btn-sm btn-primary">Daftar</a>
    <% } %>
  </div>
</header>
