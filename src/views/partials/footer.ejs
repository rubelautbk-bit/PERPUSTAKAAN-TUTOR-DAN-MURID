<footer style="background:var(--card); border-top:1px solid var(--border); padding:30px 20px; margin-top:60px;">
  <div style="max-width:1200px; margin:0 auto; display:grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr)); gap:20px;">
    <div>
      <div class="brand" style="font-weight:700; color:var(--brand); font-size:1.1rem;">
        <span>Perpustakaan Rubela</span>
      </div>
      <p class="text-muted" style="font-size:0.9rem; margin-top:8px;">
        Perpustakaan digital Bimbel Rubela Indonesia. Tempat belajar tanpa batas untuk murid dan tutor.
      </p>
    </div>
    <div>
      <h4 style="margin:0 0 8px; font-size:0.95rem;">Navigasi</h4>
      <a href="/katalog" style="display:block; padding:3px 0; color:var(--muted);">Katalog Buku</a>
      <a href="/pengumuman" style="display:block; padding:3px 0; color:var(--muted);">Pengumuman</a>
      <a href="/tentang" style="display:block; padding:3px 0; color:var(--muted);">Tentang</a>
    </div>
    <div>
      <h4 style="margin:0 0 8px; font-size:0.95rem;">Akun</h4>
      <a href="/auth/login" style="display:block; padding:3px 0; color:var(--muted);">Masuk</a>
      <a href="/auth/register" style="display:block; padding:3px 0; color:var(--muted);">Daftar</a>
    </div>
    <div>
      <h4 style="margin:0 0 8px; font-size:0.95rem;">Kontak</h4>
      <p class="text-muted" style="margin:0; font-size:0.88rem;">
        info@rubela.id<br>
        WhatsApp: 0812-0000-0000
      </p>
    </div>
  </div>
  <div class="text-center text-muted" style="margin-top:20px; font-size:0.85rem; border-top:1px solid var(--border); padding-top:14px;">
    &copy; <%= new Date().getFullYear() %> Bimbel Rubela Indonesia. All rights reserved.
  </div>
</footer>
