<h3 class="text-center mt-0"><%= t('auth.forgotTitle') %></h3>
<p class="text-muted text-center" style="margin-bottom:20px;"><%= t('auth.forgotSubtitle') %></p>
<form method="POST" action="/auth/forgot">
  <div class="form-group">
    <label><%= t('auth.email') %></label>
    <input type="email" name="email" class="form-control" required />
  </div>
  <button type="submit" class="btn btn-primary btn-block"><%= t('auth.forgotBtn') %></button>
</form>
<p class="text-center mt-2"><a href="/auth/login"><%= t('auth.backToLogin') %></a></p>
