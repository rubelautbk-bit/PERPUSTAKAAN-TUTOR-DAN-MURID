<h3 class="text-center mt-0"><%= t('auth.registerTitle') %></h3>
<p class="text-muted text-center" style="margin-bottom:20px;"><%= t('auth.registerSubtitle') %></p>

<form method="POST" action="/auth/register">
  <div class="form-group">
    <label><%= t('auth.fullName') %></label>
    <input type="text" name="name" class="form-control" required />
  </div>
  <div class="form-group">
    <label><%= t('auth.email') %></label>
    <input type="email" name="email" class="form-control" required />
  </div>
  <div class="form-group">
    <label><%= t('auth.phone') %></label>
    <input type="text" name="phone" class="form-control" placeholder="<%= t('auth.phonePlaceholder') %>" />
  </div>
  <div class="form-group">
    <label><%= t('auth.registerAs') %></label>
    <select name="role" class="form-control">
      <option value="murid"><%= t('auth.roleStudent') %></option>
      <option value="tutor"><%= t('auth.roleTutor') %></option>
    </select>
  </div>
  <div class="form-group">
    <label><%= t('auth.password') %></label>
    <input type="password" name="password" class="form-control" required minlength="6" />
  </div>
  <div class="form-group">
    <label><%= t('auth.confirmPassword') %></label>
    <input type="password" name="confirm" class="form-control" required />
  </div>
  <button type="submit" class="btn btn-primary btn-block"><%= t('auth.registerBtn') %></button>
</form>

<p class="text-center mt-2" style="font-size:0.9rem;">
  <%= t('auth.haveAccount') %> <a href="/auth/login"><%= t('nav.login') %></a>
</p>
