<h3 class="text-center mt-0">Masuk ke Akun</h3>
<p class="text-muted text-center" style="margin-bottom:20px;">Gunakan email atau nomor HP terdaftar.</p>

<form method="POST" action="/auth/login">
  <div class="form-group">
    <label>Email / No. HP</label>
    <input type="text" name="identifier" class="form-control" placeholder="email@contoh.com" required />
  </div>
  <div class="form-group">
    <label>Password</label>
    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
  </div>
  <button type="submit" class="btn btn-primary btn-block">Masuk</button>
</form>

<div class="row-flex" style="justify-content:space-between; margin-top:16px; font-size:0.9rem;">
  <a href="/auth/forgot">Lupa password?</a>
  <a href="/auth/register">Buat akun baru</a>
</div>

<div class="card mt-3" style="background:var(--brand-light); border:0; font-size:0.85rem;">
  <strong>Akun demo:</strong><br>
  Admin: <code>admin@rubela.id</code> / <code>admin123</code><br>
