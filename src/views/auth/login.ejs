<h3 class="text-center mt-0"><%= t('auth.loginTitle') %></h3>
<p class="text-muted text-center" style="margin-bottom:20px;"><%= t('auth.loginSubtitle') %></p>

<form method="POST" action="/auth/login">
  <div class="form-group">
    <label><%= t('auth.identifier') %></label>
    <input type="text" name="identifier" class="form-control" placeholder="<%= t('auth.identifierPlaceholder') %>" required />
  </div>
  <div class="form-group">
    <label><%= t('auth.password') %></label>
    <input type="password" name="password" class="form-control" placeholder="********" required />
  </div>
  <button type="submit" class="btn btn-primary btn-block"><%= t('auth.loginBtn') %></button>
</form>

<div class="row-flex" style="justify-content:space-between; margin-top:16px; font-size:0.9rem;">
  <a href="/auth/forgot"><%= t('auth.forgot') %></a>
  <a href="/auth/register"><%= t('auth.createAccount') %></a>
</div>

<div class="card mt-3" style="background:var(--brand-light); border:0; font-size:0.85rem;">
  <strong><%= t('auth.demoAccounts') %>:</strong><br>
  <%= t('role.admin') %>: <code>admin@rubela.id</code> / <code>admin123</code><br>
  <%= t('role.tutor') %>: <code>tutor@rubela.id</code> / <code>tutor123</code><br>
  <%= t('role.murid') %>: <code>murid@rubela.id</code> / <code>murid123</code>
</div>
