<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %> - CBT Rubela</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"/>
  <style>
    body { overflow: hidden; }
    .cbt-container { display: grid; grid-template-columns: 1fr 280px; height: 100vh; }
    .cbt-main { overflow-y: auto; padding: 20px; }
    .cbt-sidebar { background: var(--card); border-left: 1px solid var(--border); padding: 16px; overflow-y: auto; }
    .cbt-header { background: var(--brand); color: #fff; padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; }
    .cbt-timer { font-size: 1.5rem; font-weight: 800; font-family: monospace; }
    .soal-nav { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; margin-top: 12px; }
    .soal-nav a { display: grid; place-items: center; width: 36px; height: 36px; border-radius: 8px; background: var(--bg); border: 1px solid var(--border); font-weight: 600; font-size: 0.85rem; color: var(--text); text-decoration: none; }
    .soal-nav a.answered { background: var(--brand); color: #fff; }
    .soal-nav a.current { border: 2px solid var(--accent); }
    .violation-warning { position: fixed; top: 0; left: 0; right: 0; background: #dc2626; color: #fff; text-align: center; padding: 10px; z-index: 9999; display: none; font-weight: 700; }
    @media (max-width: 768px) { .cbt-container { grid-template-columns: 1fr; } .cbt-sidebar { display: none; } }
  </style>
</head>
<body>
  <div class="violation-warning" id="violationWarn">PERINGATAN: Jangan tinggalkan halaman ujian!</div>
  <%- body %>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
  <script>
    // Render LaTeX
    document.addEventListener('DOMContentLoaded', () => {
      renderMathInElement(document.body, {
        delimiters: [
          {left: '$$', right: '$$', display: true},
          {left: '$', right: '$', display: false},
          {left: '\\[', right: '\\]', display: true},
          {left: '\\(', right: '\\)', display: false}
        ]
      });
    });
  </script>
  <script src="/js/app.js"></script>
</body>
</html>
