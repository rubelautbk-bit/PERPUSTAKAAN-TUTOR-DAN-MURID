<div class="page-header"><div><a href="/murid/kelas">&larr; Kelas</a><h1><%=kelas.nama%></h1><p class="subtitle">Tutor: <%=kelas.tutor_name%> | Kode: <code><%=kelas.kode%></code></p></div></div><div class="grid-2"><div class="card"><h3>Materi & Modul</h3><%if(!materi.length){%><p class="text-muted">Belum ada materi.</p><%}%><%materi.forEach(m=>{%><div style="padding:8px 0;border-bottom:1px solid var(--border)"><span class="badge"><%=m.tipe%></span> <strong><%=m.judul%></strong><%if(m.buku_judul){%><div class="text-muted" style="font-size:0.85rem">Buku: <a href="/buku/<%=m.buku_id%>"><%=m.buku_judul%></a></div><%}%><%if(m.link){%><a href="<%=m.link%>" target="_blank" class="btn btn-sm btn-secondary">Link</a><%}%></div><%})%></div><div class="card"><h3>Rekomendasi Buku</h3><%rekomendasi.forEach(r=>{%><div style="padding:8px 0;border-bottom:1px solid var(--border)"><a href="/buku/<%=r.buku_id%>" style="font-weight:600;color:var(--text)"><%=r.judul%></a><div class="text-muted" style="font-size:0.85rem"><%=r.penulis%><%if(r.catatan){%> - <%=r.catatan%><%}%></div></div><%})%><%if(!rekomendasi.length){%><p class="text-muted">Belum ada rekomendasi.</p><%}%></div></div><%if(ujian.length){%><div class="card mt-3"><h3>Ujian/Kuis di Kelas Ini</h3><%ujian.forEach(u=>{%><div style="padding:8px 0;border-bottom:1px solid var(--border)"><a href="/murid/ujian/<%=u.id%>/kerjakan" class="btn btn-sm btn-primary">Kerjakan</a> <strong><%=u.judul%></strong> (<%=u.durasi_menit%> menit)</div><%})%></div><%}%>