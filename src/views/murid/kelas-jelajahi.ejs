<div class="page-header"><h1>Jelajahi Kelas</h1></div><div class="card"><h3>Gabung dengan Kode</h3><form method="POST" action="/murid/kelas/join" class="row-flex"><input name="kode" class="form-control" style="max-width:200px" placeholder="Kode kelas" required/><button class="btn btn-primary">Gabung</button></form></div><div class="grid-3 mt-3"><%semua.forEach(k=>{%><div class="card"><span class="badge"><%=k.subtest||"Umum"%></span><h3 style="margin:8px 0"><%=k.nama%></h3><p class="text-muted">Tutor: <%=k.tutor_name%> | <%=k.jumlah%> murid</p><p class="text-muted" style="font-size:0.85rem">Kode: <code><%=k.kode%></code></p></div><%})%></div>