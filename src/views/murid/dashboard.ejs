<div class="page-header"><div><h1>Dashboard</h1><p class="subtitle">Halo, <%=user.name%>!</p></div><a href="/katalog" class="btn btn-primary">Cari Buku</a></div><div class="stat-grid"><div class="stat"><div class="label">Dipinjam</div><div class="value"><%=s.pinjam%></div></div><div class="stat accent"><div class="label">Wishlist</div><div class="value"><%=s.wishlist%></div></div><div class="stat blue"><div class="label">Selesai</div><div class="value"><%=s.selesai%></div></div><div class="stat"><div class="label">Level</div><div class="value">Lv <%=me?me.level:1%></div></div><div class="stat red"><div class="label">Poin</div><div class="value"><%=me?me.poin:0%></div></div></div><div class="grid-2"><div class="card"><h3>Buku Dipinjam</h3><%if(!bukuAktif.length){%><p class="text-muted">Belum ada. <a href="/katalog">Cari buku</a></p><%}%><%bukuAktif.forEach(p=>{%><div style="padding:8px 0;border-bottom:1px solid var(--border)"><strong><%=p.judul%></strong><div class="text-muted" style="font-size:0.85rem">Kembali: <%=p.tanggal_kembali%></div></div><%})%></div><div class="card"><h3>Ujian Aktif</h3><%if(!ujianAktif.length){%><p class="text-muted">Tidak ada ujian aktif.</p><%}%><%ujianAktif.forEach(u=>{%><div style="padding:8px 0;border-bottom:1px solid var(--border)"><a href="/murid/ujian/<%=u.id%>/kerjakan" style="font-weight:600;color:var(--text)"><%=u.judul%></a><div class="text-muted" style="font-size:0.85rem"><%=u.tipe%> | <%=u.durasi_menit%> menit</div></div><%})%></div></div><div class="card mt-3"><h3>Rekomendasi Buku</h3><div class="book-grid"><%rekomendasi.forEach(b=>{%><a href="/buku/<%=b.id%>" class="book-card"><div class="book-cover"><%=b.judul%></div><div class="book-info"><div class="title"><%=b.judul%></div><div class="author"><%=b.penulis%></div></div></a><%})%></div></div>