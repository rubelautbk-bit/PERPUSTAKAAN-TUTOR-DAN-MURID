<div class="page-header">
  <div><h1><%= t('student.dashboardTitle') %></h1><p class="subtitle"><%= t('student.greeting', { name: user.name }) %></p></div>
  <a href="/katalog" class="btn btn-primary"><%= t('student.searchBookBtn') %></a>
</div>

<div class="stat-grid">
  <div class="stat"><div class="label"><%= t('student.statBorrowing') %></div><div class="value"><%= s.pinjam %></div></div>
  <div class="stat accent"><div class="label"><%= t('student.statWishlist') %></div><div class="value"><%= s.wishlist %></div></div>
  <div class="stat blue"><div class="label"><%= t('student.statFinished') %></div><div class="value"><%= s.selesai %></div></div>
  <div class="stat"><div class="label"><%= t('student.statLevel') %></div><div class="value">Lv <%= me ? me.level : 1 %></div></div>
  <div class="stat red"><div class="label"><%= t('student.statPoints') %></div><div class="value"><%= me ? me.poin : 0 %></div></div>
</div>

<div class="grid-2">
  <div class="card">
    <div class="page-header">
      <h3 style="margin:0;"><%= t('student.borrowedBooks') %></h3>
      <a href="/murid/buku-saya" class="btn btn-sm btn-secondary"><%= t('common.seeAll') %></a>
    </div>
    <% if (bukuAktif.length === 0) { %>
      <p class="text-muted"><%= t('student.noBorrowedBooks') %> <a href="/katalog"><%= t('student.exploreCatalog') %></a></p>
    <% } %>
    <% bukuAktif.forEach(p => { %>
      <div style="padding:10px 0; border-bottom:1px solid var(--border);">
        <strong><%= p.judul %></strong>
        <div class="text-muted" style="font-size:0.85rem;"><%= t('student.returnBy', { date: p.tanggal_kembali }) %></div>
      </div>
    <% }) %>
  </div>

  <div class="card">
    <h3><%= t('student.readingProgress') %></h3>
    <% if (progress.length === 0) { %><p class="text-muted"><%= t('student.noProgress') %></p><% } %>
    <% progress.forEach(p => { %>
      <div style="padding:8px 0;">
        <strong><%= p.judul %></strong>
        <div class="progress mt-1"><div class="bar" style="width: <%= p.persentase %>%"></div></div>
        <small class="text-muted"><%= p.persentase %>% &middot; <%= t('reader.pageShort') %> <%= p.halaman_terakhir %></small>
      </div>
    <% }) %>
  </div>
</div>

<div class="card mt-3">
  <div class="page-header">
    <div>
      <h3 style="margin:0;">&#129504; <%= t('student.smartRecTitle') %></h3>
      <p class="subtitle"><%= t('student.smartRecDesc') %></p>
    </div>
  </div>
  <% if (rekomendasiSmart.length === 0) { %><p class="text-muted"><%= t('student.noSmartRec') %></p><% } %>
  <div class="book-grid">
    <% rekomendasiSmart.forEach(b => { %>
      <a href="/buku/<%= b.id %>" class="book-card">
        <div class="book-cover"><%= b.judul %></div>
        <div class="book-info">
          <div class="title"><%= b.judul %></div>
          <div class="author"><%= b.penulis %></div>
          <div class="meta">
            <span class="badge" style="font-size:0.7rem;"><%= b.kategori_nama %></span>
            <span><span class="rating-star">&#9733;</span> <%= b.rating %></span>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</div>

<div class="grid-2 mt-3">
  <div class="card">
    <h3><%= t('student.tutorRec') %></h3>
    <% if (rekomendasi.length === 0) { %><p class="text-muted"><%= t('student.noTutorRec') %></p><% } %>
    <% rekomendasi.forEach(r => { %>
      <div style="padding:10px 0; border-bottom:1px solid var(--border);">
        <a href="/buku/<%= r.buku_id %>" style="font-weight:600; color:var(--text);"><%= r.judul %></a>
        <div class="text-muted" style="font-size:0.85rem;"><%= t('student.recommendedBy', { tutor: r.tutor_name }) %></div>
        <% if (r.catatan) { %><p style="margin:4px 0; font-size:0.9rem;">&quot;<%= r.catatan %>&quot;</p><% } %>
      </div>
    <% }) %>
  </div>

  <div class="card">
    <div class="page-header">
      <h3 style="margin:0;"><%= t('student.notifBlockTitle') %></h3>
      <a href="/murid/notifikasi" class="btn btn-sm btn-secondary"><%= t('student.all') %></a>
    </div>
    <% if (notif.length === 0) { %><p class="text-muted"><%= t('student.noNotif') %></p><% } %>
    <% notif.forEach(n => { %>
      <div style="padding:8px 0; border-bottom:1px solid var(--border);">
        <strong><%= n.judul %></strong>
        <p style="margin:4px 0; font-size:0.9rem;"><%= n.pesan %></p>
        <small class="text-muted"><%= new Date(n.created_at).toLocaleDateString(lang === 'en' ? 'en-US' : 'id-ID') %></small>
      </div>
    <% }) %>
  </div>
</div>
