<div class="page-header"><h1>Profile Saya</h1></div>

<div class="grid-2">
  <div class="card">
    <h3>Informasi Akun</h3>
    <form method="POST" action="/murid/profile">
      <div class="form-group"><label>Nama Lengkap</label><input name="name" class="form-control" value="<%= u.name %>" required/></div>
      <div class="form-group"><label>Email</label><input type="email" name="email" class="form-control" value="<%= u.email %>" required/></div>
      <div class="form-group"><label>No HP</label><input name="phone" class="form-control" value="<%= u.phone || '' %>"/></div>
      <button class="btn btn-primary">Simpan</button>
    </form>
  </div>
  <div class="card">
    <h3>Detail Akun</h3>
    <table class="tbl">
      <tr><td><strong>Role</strong></td><td><span class="badge"><%= u.role %></span></td></tr>
      <tr><td><strong>Status</strong></td><td><span class="badge <%= u.status==='suspended'?'red':'' %>"><%= u.status %></span></td></tr>
      <tr><td><strong>Bergabung</strong></td><td><%= new Date(u.created_at).toLocaleDateString('id-ID') %></td></tr>
    </table>

    <h4 class="mt-3">Gamifikasi</h4>
    <div class="row-flex">
      <span class="badge">Pembaca Aktif</span>
      <span class="badge blue">Lv 1</span>
      <span class="badge warn">100 Poin</span>
    </div>
  </div>
</div>
