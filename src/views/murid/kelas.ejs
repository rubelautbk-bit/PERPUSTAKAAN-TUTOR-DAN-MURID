<div class="page-header"><h1>Kelas Saya</h1><a href="/murid/kelas/jelajahi" class="btn btn-secondary">Jelajahi Kelas</a></div><%if(!myKelas.length){%><div class="card text-center" style="padding:40px"><h3>Belum bergabung kelas</h3><p class="text-muted">Gunakan kode kelas atau jelajahi kelas yang tersedia.</p><a href="/murid/kelas/jelajahi" class="btn btn-primary">Jelajahi</a></div><%}%><div class="grid-3"><%myKelas.forEach(k=>{%><div class="card"><span class="badge"><%=k.subtest||"Umum"%></span><h3 style="margin:8px 0"><a href="/murid/kelas/<%=k.id%>" style="color:var(--text)"><%=k.nama%></a></h3><p class="text-muted">Tutor: <%=k.tutor_name%></p><a href="/murid/kelas/<%=k.id%>" class="btn btn-sm btn-primary">Masuk</a></div><%})%></div>