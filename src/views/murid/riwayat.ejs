<div class="page-header"><h1>Riwayat Aktivitas</h1></div><div class="card"><%aktivitas.forEach(a=>{%><div style="padding:8px 0;border-bottom:1px solid var(--border)"><strong><%=a.aksi%></strong> <span class="text-muted" style="font-size:0.85rem"><%=new Date(a.created_at).toLocaleString("id-ID")%></span><%if(a.detail){%><div class="text-muted" style="font-size:0.9rem"><%=a.detail%></div><%}%></div><%})%><%if(!aktivitas.length){%><p class="text-muted">Belum ada aktivitas.</p><%}%></div>