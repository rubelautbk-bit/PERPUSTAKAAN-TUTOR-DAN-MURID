<div class="page-header"><h1>Chat</h1></div><div class="card"><%rooms.forEach(r=>{%><div style="padding:8px 0;border-bottom:1px solid var(--border)"><a href="/murid/chat/<%=r.id%>" style="font-weight:600;color:var(--text)"><%=r.nama||("Room "+r.id)%></a><%if(r.last_msg){%><div class="text-muted" style="font-size:0.85rem"><%=r.last_msg.substring(0,50)%></div><%}%></div><%})%><%if(!rooms.length){%><p class="text-muted">Belum ada percakapan.</p><%}%></div>