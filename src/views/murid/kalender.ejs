<div class="page-header"><h1>Kalender Kegiatan</h1></div><div class="card"><%events.forEach(e=>{%><div style="padding:10px 0;border-bottom:1px solid var(--border)"><span class="badge"><%=e.tipe%></span> <strong><%=e.judul%></strong><div class="text-muted" style="font-size:0.85rem"><%=e.tanggal_mulai%><%if(e.deskripsi){%> - <%=e.deskripsi%><%}%></div></div><%})%><%if(!events.length){%><p class="text-muted">Tidak ada jadwal.</p><%}%></div>