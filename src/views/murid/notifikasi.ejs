<div class="page-header"><h1>Notifikasi</h1></div>

<div class="card">
  <% if (list.length === 0) { %>
    <p class="text-muted text-center">Tidak ada notifikasi.</p>
  <% } %>
  <% list.forEach(n => { %>
    <div style="padding:12px 0; border-bottom:1px solid var(--border);">
      <span class="badge <%= n.tipe==='sukses' ? '' : n.tipe==='info' ? 'blue' : n.tipe==='warning' ? 'warn' : 'gray' %>"><%= n.tipe %></span>
      <strong style="margin-left:6px;"><%= n.judul %></strong>
      <p style="margin:4px 0;"><%= n.pesan %></p>
      <small class="text-muted"><%= new Date(n.created_at).toLocaleString('id-ID') %></small>
    </div>
  <% }) %>
</div>
