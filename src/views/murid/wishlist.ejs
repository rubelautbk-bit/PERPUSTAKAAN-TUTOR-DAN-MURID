<div class="page-header"><h1>Wishlist Saya</h1></div>

<% if (rows.length === 0) { %>
  <div class="card text-center" style="padding:50px;">
    <h3>Belum ada buku di wishlist</h3>
    <p class="text-muted">Tambahkan buku favorit dari katalog.</p>
    <a href="/katalog" class="btn btn-primary">Jelajahi Katalog</a>
  </div>
<% } else { %>
  <div class="book-grid">
    <% rows.forEach(b => { %>
      <div class="book-card">
        <a href="/buku/<%= b.id %>">
          <div class="book-cover"><%= b.judul %></div>
        </a>
        <div class="book-info">
          <div class="title"><%= b.judul %></div>
          <div class="author"><%= b.penulis %></div>
          <form method="POST" action="/murid/wishlist/<%= b.wid %>?_method=DELETE" class="mt-1">
            <button class="btn btn-sm btn-danger btn-block">Hapus</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
