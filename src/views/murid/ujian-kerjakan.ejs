<div class="cbt-header">
  <div>
    <strong><%= uj.judul %></strong>
    <span class="badge" style="background:#fff3;color:#fff;margin-left:8px;"><%= uj.tipe %></span>
  </div>
  <div class="cbt-timer" id="timer">--:--:--</div>
  <button class="btn btn-warning" onclick="submitUjian()">Selesai &amp; Kumpulkan</button>
</div>

<div class="cbt-container">
  <div class="cbt-main" id="soalContainer">
    <% soalList.forEach(function(s, i) { %>
      <div class="soal-item card" id="soal-<%= i %>" style="<%= i > 0 ? 'display:none;' : '' %>">
        <div class="row-flex" style="justify-content:space-between; margin-bottom:10px;">
          <span class="badge"><%= s.subtest %> | <%= s.tipe %></span>
          <span class="text-muted">Soal <%= i+1 %>/<%= soalList.length %> | Poin: <%= s.poin %></span>
        </div>
        <div class="soal-text latex-render" style="font-size:1.05rem; line-height:1.7; margin-bottom:16px;"><%- s.soal %></div>

        <% 
        var opsi = [];
        try { opsi = JSON.parse(s.opsi_json || '[]'); } catch(e){}
        var letters = ['A','B','C','D','E','F'];
        %>

        <% if (s.tipe === 'pg') { %>
          <% opsi.forEach(function(o, oi) { %>
            <label class="opsi-label" style="display:flex; gap:10px; padding:10px; border:1px solid var(--border); border-radius:8px; margin-bottom:8px; cursor:pointer;">
              <input type="radio" name="ans_<%= s.id %>" value="<%= letters[oi] %>" onchange="markAnswered(<%= i %>)"/>
              <span><strong><%= letters[oi] %>.</strong> <span class="latex-render"><%- o %></span></span>
            </label>
          <% }) %>
        <% } else if (s.tipe === 'pg_kompleks') { %>
          <p class="text-muted" style="font-size:0.88rem;">Pilih lebih dari satu jawaban yang benar:</p>
          <% opsi.forEach(function(o, oi) { %>
            <label class="opsi-label" style="display:flex; gap:10px; padding:10px; border:1px solid var(--border); border-radius:8px; margin-bottom:8px; cursor:pointer;">
              <input type="checkbox" name="ans_<%= s.id %>" value="<%= letters[oi] %>" onchange="markAnswered(<%= i %>)"/>
              <span><strong><%= letters[oi] %>.</strong> <span class="latex-render"><%- o %></span></span>
            </label>
          <% }) %>
        <% } else if (s.tipe === 'benar_salah') { %>
          <label style="display:flex; gap:10px; padding:10px; border:1px solid var(--border); border-radius:8px; margin-bottom:8px; cursor:pointer;">
            <input type="radio" name="ans_<%= s.id %>" value="true" onchange="markAnswered(<%= i %>)"/> <span>Benar</span>
          </label>
          <label style="display:flex; gap:10px; padding:10px; border:1px solid var(--border); border-radius:8px; margin-bottom:8px; cursor:pointer;">
            <input type="radio" name="ans_<%= s.id %>" value="false" onchange="markAnswered(<%= i %>)"/> <span>Salah</span>
          </label>
        <% } else if (s.tipe === 'isian' || s.tipe === 'cloze') { %>
          <input type="text" name="ans_<%= s.id %>" class="form-control" placeholder="Ketik jawaban singkat..." oninput="markAnswered(<%= i %>)"/>
        <% } else if (s.tipe === 'esai') { %>
          <textarea name="ans_<%= s.id %>" class="form-control" rows="6" placeholder="Tulis uraian jawaban..." oninput="markAnswered(<%= i %>)"></textarea>
          <p class="text-muted" style="font-size:0.82rem; margin-top:6px;">&#9432; Soal esai akan dinilai manual oleh tutor.</p>
        <% } else if (s.tipe === 'menjodohkan') { %>
          <textarea name="ans_<%= s.id %>" class="form-control" rows="3" placeholder="Jawaban menjodohkan..." oninput="markAnswered(<%= i %>)"></textarea>
        <% } else { %>
          <textarea name="ans_<%= s.id %>" class="form-control" rows="3" oninput="markAnswered(<%= i %>)"></textarea>
        <% } %>

        <div class="row-flex mt-3" style="justify-content:space-between;">
          <button class="btn btn-secondary" onclick="navigasi(<%= i-1 %>)" <%= i===0?'disabled':'' %>>&laquo; Sebelumnya</button>
          <button class="btn btn-primary" onclick="navigasi(<%= i+1 %>)" <%= i===soalList.length-1?'disabled':'' %>>Berikutnya &raquo;</button>
        </div>
      </div>
    <% }) %>
  </div>

  <aside class="cbt-sidebar">
    <h4>Navigasi Soal</h4>
    <div class="soal-nav" id="soalNav">
      <% soalList.forEach(function(s, i) { %>
        <a href="#" onclick="navigasi(<%= i %>);return false;" id="nav-<%= i %>" class="<%= i===0?'current':'' %>"><%= i+1 %></a>
      <% }) %>
    </div>
    <div class="mt-3">
      <div class="row-flex" style="gap:8px; font-size:0.82rem;">
        <span style="width:14px; height:14px; background:var(--brand); border-radius:4px; display:inline-block;"></span> Dijawab
        <span style="width:14px; height:14px; background:var(--bg); border:1px solid var(--border); border-radius:4px; display:inline-block;"></span> Belum
      </div>
    </div>
    <div class="card mt-3" style="background:var(--bg);">
      <strong>Info Ujian</strong><br/>
      <small>Durasi: <%= uj.durasi_menit %> menit</small><br/>
      <small>Jumlah: <%= soalList.length %> soal</small><br/>
      <% if (uj.poin_negatif > 0) { %><small style="color:#dc2626;">Poin negatif: -<%= uj.poin_negatif %></small><% } %>
    </div>
  </aside>
</div>

<script>
const ujianId = <%= uj.id %>;
const totalSoal = <%= soalList.length %>;
const durasiDetik = <%= uj.durasi_menit %> * 60;
const antiCheat = <%= uj.anti_cheat ? 'true' : 'false' %>;
const soalIds = <%- JSON.stringify(soalList.map(s => s.id)) %>;
let currentSoal = 0;
let sisaWaktu = durasiDetik;
let violations = 0;

// Timer
const timerEl = document.getElementById('timer');
const interval = setInterval(() => {
  sisaWaktu--;
  if (sisaWaktu <= 0) { clearInterval(interval); submitUjian(true); return; }
  const h = Math.floor(sisaWaktu/3600), m = Math.floor((sisaWaktu%3600)/60), s = sisaWaktu%60;
  timerEl.textContent = String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  if (sisaWaktu < 60) timerEl.style.color = '#dc2626';
}, 1000);

function navigasi(idx) {
  if (idx < 0 || idx >= totalSoal) return;
  document.getElementById('soal-'+currentSoal).style.display = 'none';
  document.getElementById('soal-'+idx).style.display = '';
  document.getElementById('nav-'+currentSoal).classList.remove('current');
  document.getElementById('nav-'+idx).classList.add('current');
  currentSoal = idx;
}
function markAnswered(idx) { document.getElementById('nav-'+idx).classList.add('answered'); }

function collectAnswers() {
  const jawaban = {};
  soalIds.forEach(id => {
    const radios = document.querySelectorAll('input[name="ans_'+id+'"][type="radio"]:checked');
    const checks = document.querySelectorAll('input[name="ans_'+id+'"][type="checkbox"]:checked');
    const texts = document.querySelectorAll('input[name="ans_'+id+'"][type="text"], textarea[name="ans_'+id+'"]');
    if (radios.length) jawaban[id] = radios[0].value;
    else if (checks.length) jawaban[id] = Array.from(checks).map(c=>c.value);
    else if (texts.length) jawaban[id] = texts[0].value;
  });
  return jawaban;
}

async function submitUjian(auto) {
  if (!auto && !confirm('Yakin ingin mengumpulkan jawaban?')) return;
  clearInterval(interval);
  try {
    const res = await fetch('/murid/ujian/'+ujianId+'/submit', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ jawaban: collectAnswers() })
    });
    const data = await res.json();
    if (data.ok) {
      // Redirect ke halaman hasil dengan pembahasan
      window.location.href = '/murid/ujian/'+ujianId+'/hasil';
    }
  } catch(e) { alert('Gagal submit: '+e.message); }
}

// Anti-cheat
if (antiCheat) {
  const warn = document.getElementById('violationWarn');
  function rapor() {
    violations++;
    if (warn) { warn.style.display='block'; setTimeout(()=>warn.style.display='none', 3000); }
    fetch('/murid/ujian/'+ujianId+'/violation', {method:'POST',headers:{'Content-Type':'application/json'},body:'{}'}).catch(()=>{});
    if (violations >= 3) { alert('Anda sudah 3 kali melanggar. Ujian otomatis dikumpulkan.'); submitUjian(true); }
  }
  document.addEventListener('visibilitychange', () => { if (document.hidden) rapor(); });
  window.addEventListener('blur', rapor);
  document.addEventListener('contextmenu', e => e.preventDefault());
  document.addEventListener('keydown', e => {
    if (e.ctrlKey && ['c','v','u','p','s'].includes(e.key.toLowerCase())) e.preventDefault();
    if (e.key === 'F12') e.preventDefault();
  });
  // Anti multi-login
  const marker = 'cbt_'+ujianId+'_'+Date.now();
  localStorage.setItem('cbt_marker_'+ujianId, marker);
  setInterval(() => {
    if (localStorage.getItem('cbt_marker_'+ujianId) !== marker) {
      alert('Terdeteksi login dari perangkat/tab lain! Ujian otomatis dikumpulkan.');
      submitUjian(true);
    }
  }, 2000);
}

// Render LaTeX
document.addEventListener('DOMContentLoaded', () => {
  if (window.renderMathInElement) {
    document.querySelectorAll('.latex-render').forEach(el => {
      renderMathInElement(el, {
        delimiters: [
          {left:'$$',right:'$$',display:true},
          {left:'$',right:'$',display:false},
          {left:'\\[',right:'\\]',display:true}
        ]
      });
    });
  }
});
</script>
