<div class="page-header">
  <div>
    <h1>Leaderboard</h1>
    <p class="subtitle">Murid paling aktif di perpustakaan Rubela</p>
  </div>
</div>

<div class="grid-2">
  <div class="card">
    <h3>Peringkat Teratas</h3>
    <table class="tbl">
      <thead><tr><th style="width:60px;">#</th><th>Nama</th><th>Level</th><th>Poin</th></tr></thead>
      <tbody>
        <% leaderboard.forEach((u, i) => { %>
          <tr <%= u.id === user.id ? 'style="background: var(--brand-light);"' : '' %>>
            <td>
              <% if (i === 0) { %><span style="font-size:1.3rem;">&#127942;</span>
              <% } else if (i === 1) { %><span style="font-size:1.3rem;">&#129352;</span>
              <% } else if (i === 2) { %><span style="font-size:1.3rem;">&#129353;</span>
              <% } else { %><strong><%= i+1 %></strong><% } %>
            </td>
            <td>
              <strong><%= u.name %></strong>
              <% if (u.id === user.id) { %> <span class="badge">Kamu</span><% } %>
            </td>
            <td><span class="badge blue">Lv <%= u.level %></span></td>
            <td><strong><%= u.poin %></strong> poin</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h3>Status Kamu</h3>
    <div class="text-center" style="padding:20px;">
      <div style="font-size:3rem; font-weight:800; color:var(--brand);">Lv <%= me.level %></div>
      <p class="text-muted"><%= me.poin %> / <%= (me.level) * 100 %> poin menuju level berikutnya</p>
      <div class="progress"><div class="bar" style="width: <%= Math.min(100, (me.poin % 100)) %>%;"></div></div>
    </div>

    <h4 class="mt-2">Badge Kamu (<%= badges.length %>)</h4>
    <% if (badges.length === 0) { %>
      <p class="text-muted" style="font-size:0.9rem;">Belum ada badge. Baca buku & kerjakan quiz untuk dapat badge!</p>
    <% } %>
    <div class="row-flex">
      <% badges.forEach(b => { %>
        <div style="background: var(--brand-light); border-radius:8px; padding:10px; text-align:center; min-width:100px;">
          <div style="font-size:1.6rem;">
            <% if (b.icon==='crown') { %>&#128081;
            <% } else if (b.icon==='trophy') { %>&#127942;
            <% } else if (b.icon==='pen') { %>&#9999;&#65039;
            <% } else if (b.icon==='book') { %>&#128218;
            <% } else { %>&#11088;<% } %>
          </div>
          <strong style="font-size:0.85rem;"><%= b.nama %></strong>
          <p class="text-muted" style="font-size:0.75rem; margin:2px 0 0;"><%= b.deskripsi %></p>
        </div>
      <% }) %>
    </div>

    <h4 class="mt-3">Cara Dapat Poin</h4>
    <ul style="font-size:0.9rem;">
      <li>Pinjam buku pertama: <strong>+10 poin</strong></li>
      <li>Kembalikan buku tepat waktu: <strong>+5 poin</strong></li>
      <li>Nilai quiz &ge; 80: <strong>+20 poin</strong></li>
      <li>Kasih rating/ulasan: <strong>+2 poin</strong></li>
      <li>Baca sampai selesai: <strong>+15 poin</strong></li>
    </ul>
  </div>
</div>
