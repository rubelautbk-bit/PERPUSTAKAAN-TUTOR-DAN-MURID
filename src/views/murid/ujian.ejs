<div class="page-header"><h1>Ujian & Kuis</h1></div><table class="tbl"><thead><tr><th>Judul</th><th>Tipe</th><th>Durasi</th><th>Status</th><th>Nilai</th><th>Aksi</th></tr></thead><tbody><%list.forEach(u=>{%><tr><td><strong><%=u.judul%></strong></td><td><span class="badge"><%=u.tipe%></span></td><td><%=u.durasi_menit%> mnt</td><td><%if(u.my_status==="selesai"){%><span class="badge">Selesai</span><%}else{%><span class="badge warn">Belum</span><%}%></td><td><%=u.my_nilai!=null?u.my_nilai:"-"%></td><td><%if(u.my_status!=="selesai"){%><a href="/murid/ujian/<%=u.id%>/kerjakan" class="btn btn-sm btn-primary">Kerjakan</a><%}%></td></tr><%})%><%if(!list.length){%><tr><td colspan="6" class="text-muted text-center">Tidak ada ujian aktif.</td></tr><%}%></tbody></table>